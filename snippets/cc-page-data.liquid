{% liquid
  assign cc_page_key = 'home'

  if template.name == 'page'
    assign cc_page_key = page.handle | default: 'page'
  elsif template.name == 'collection'
    assign cc_page_key = 'collection'
  elsif template.name == 'product'
    assign cc_page_key = 'product'
  elsif template.name == 'search'
    assign cc_page_key = 'search'
  elsif template.name == 'cart'
    assign cc_page_key = 'cart'
  endif

  assign cc_page_data = blank
  if shop.metafields.cloudcannon.pages[cc_page_key] != blank
    assign cc_page_data = shop.metafields.cloudcannon.pages[cc_page_key].value
  endif
%}
<script type="application/json" id="cc-page-data">
  {{ cc_page_data | json }}
</script>
