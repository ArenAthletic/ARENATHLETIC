{% liquid
  assign cc_page_key = 'home'
  if template.name == 'page'
    assign cc_page_key = page.handle | default: 'page'
  elsif template.name == 'collection'
    assign cc_page_key = 'collection'
  elsif template.name == 'product'
    assign cc_page_key = 'product'
  endif

  assign cc_page = shop.metafields.cloudcannon.pages[cc_page_key].value
  assign cc_site = shop.metafields.cloudcannon.site.value
%}
