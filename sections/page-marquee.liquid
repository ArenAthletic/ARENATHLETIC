{% liquid
  assign target_page = section.settings.page
  assign current_page_handle = page.handle | default: handle
  assign target_page_handle = blank
  assign page_data = blank
  assign section_data = blank
  assign section_key = section.id | split: '__' | first | replace: '-', '_'
  if target_page != blank
    assign target_page_handle = target_page.handle
  endif
  if target_page_handle != blank and target_page_handle != current_page_handle
    break
  endif
  if shop.metafields.cloudcannon.pages[current_page_handle] != blank
    assign page_data = shop.metafields.cloudcannon.pages[current_page_handle].value
  endif
  if page_data != blank and page_data[section_key] != blank
    assign section_data = page_data[section_key]
  elsif page_data != blank and page_data.marquee != blank
    assign section_data = page_data.marquee
  endif
%}

<div data-editable="component" data-component="page-marquee" data-path="sections/page-marquee.liquid" data-key="{{ section_key }}">
<div class="marquee-strip" data-editable="source" data-path="data/pages/{{ current_page_handle }}.json" data-key="{{ section_key }}">
  <div class="marquee-track">
    <span class="marquee-text" data-editable="text" data-prop="{{ section_key }}.text">{{ section_data.text | default: section.settings.text }}</span>
    <span class="marquee-text" data-editable="text" data-prop="{{ section_key }}.text">{{ section_data.text | default: section.settings.text }}</span>
  </div>
</div>
</div>

{% schema %}
{
  "name": "Page marquee",
  "settings": [
    { "type": "page", "id": "page", "label": "Display on page" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "AREN ATHLETIC — NEW YORK CITY — DISCIPLINE AND PERFORMANCE — STREET MILES NYC — FIVE BOROUGH CHAPTER — STRUCTURED PERFORMANCE — AREN ATHLETIC COLLECTIVE — APPAREL BUILT FOR TRAINING —" }
  ],
  "presets": [
    { "name": "Page marquee" }
  ]
}
{% endschema %}
