<section class="hero-section" style="padding: 60px 0; background-color: {{ section.settings.bg_color }};" {{ section.shopify_attributes }}>
  <div class="container" style="max-width: 1200px; margin: 0 auto; text-align: center;">
    {% for block in section.blocks %}
      <div class="hero-block-item" {{ block.shopify_attributes }} style="margin-bottom: 20px;">
        {% case block.type %}
          {% when 'heading' %}
            <h1 style="font-size: 3rem; margin: 0;">{{ block.settings.title }}</h1>

          {% when 'text' %}
            <div class="hero-description" style="font-size: 1.2rem;">
              {{ block.settings.content }}
            </div>

          {% when 'button' %}
            <a href="{{ block.settings.link }}" class="button" style="display: inline-block; padding: 12px 24px; background: #000; color: #fff; text-decoration: none; border-radius: 4px;">
              {{ block.settings.label }}
            </a>
        {% endcase %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Draggable Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Heading Text", "default": "Elevate Your Training" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        { "type": "richtext", "id": "content", "label": "Description", "default": "<p>Experience the next level of athletic performance.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "label", "label": "Button Label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Draggable Hero",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
