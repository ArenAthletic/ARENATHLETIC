{% liquid
  assign target_page = section.settings.page
  assign current_page_handle = page.handle | default: handle
  assign target_page_handle = blank
  assign page_data = blank
  assign section_data = blank
  assign section_key = section.id | split: '__' | first | replace: '-', '_'
  if target_page != blank
    assign target_page_handle = target_page.handle
  endif
  if target_page_handle != blank and target_page_handle != current_page_handle
    break
  endif
  if shop.metafields.cloudcannon.pages[current_page_handle] != blank
    assign page_data = shop.metafields.cloudcannon.pages[current_page_handle].value
  endif
  if page_data != blank and page_data[section_key] != blank
    assign section_data = page_data[section_key]
  endif
%}

<div data-editable="component" data-component="page-card-list" data-path="sections/page-card-list.liquid" data-key="{{ section_key }}">
<section class="section" style="{% if section_data.dark_theme | default: section.settings.dark_theme %}background:var(--color-black);color:var(--color-white);{% endif %}" data-editable="source" data-path="data/pages/{{ current_page_handle }}.json" data-key="{{ section_key }}">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:start;">
      <div>
        {% if section_data.eyebrow != blank or section.settings.eyebrow != blank %}
          <div class="text-eyebrow" data-editable="text" data-prop="{{ section_key }}.eyebrow" style="margin-bottom:2rem;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.3);{% endif %}">{{ section_data.eyebrow | default: section.settings.eyebrow }}</div>
        {% endif %}
        {% if section_data.heading != blank or section.settings.heading != blank %}
          <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3.8rem);font-weight:700;line-height:0.95;letter-spacing:-0.01em;text-transform:uppercase;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:#fff;{% endif %};margin-bottom:2rem;" data-editable="text" data-prop="{{ section_key }}.heading">{{ section_data.heading | default: section.settings.heading }}</h2>
        {% endif %}
        {% if section_data.copy != blank or section.settings.copy != blank %}
          <div class="rte" data-editable="text" data-prop="{{ section_key }}.copy" style="font-size:1rem;line-height:1.75;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.55);{% else %}color:var(--color-dark-gray);{% endif %};max-width:46ch;">{{ section_data.copy | default: section.settings.copy }}</div>
        {% endif %}
        {% if section_data.kicker != blank or section.settings.kicker != blank %}
          <p style="font-family:var(--font-mono);font-size:0.625rem;letter-spacing:0.2em;text-transform:uppercase;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.35);{% else %}color:var(--color-mid-gray);{% endif %};margin-top:1rem;" data-editable="text" data-prop="{{ section_key }}.kicker">{{ section_data.kicker | default: section.settings.kicker }}</p>
        {% endif %}
      </div>
      <div style="display:flex;flex-direction:column;gap:2rem;padding-left:var(--space-lg);{% if section_data.dark_theme | default: section.settings.dark_theme %}border-left:1px solid rgba(255,255,255,0.08);{% else %}border-left:1px solid var(--color-warm-gray);{% endif %}" data-editable="array" data-prop="{{ section_key }}.cards">
        {% if section_data.cards != blank %}
          {% for card in section_data.cards %}
            <div style="padding:2.5rem;{% if section_data.dark_theme | default: section.settings.dark_theme %}background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);{% else %}background:rgba(0,0,0,0.02);border:1px solid var(--color-warm-gray);{% endif %}" data-editable="array-item" data-prop="{{ section_key }}.cards[{{ forloop.index0 }}]">
              <div class="text-eyebrow" style="margin-bottom:1rem;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.3);{% endif %}" data-editable="text" data-prop="{{ section_key }}.cards[{{ forloop.index0 }}].title">{{ card.title }}</div>
              <p style="font-size:0.9375rem;line-height:1.7;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.5);{% else %}color:var(--color-dark-gray);{% endif %};" data-editable="text" data-prop="{{ section_key }}.cards[{{ forloop.index0 }}].description">{{ card.description }}</p>
            </div>
          {% endfor %}
        {% else %}
          {% for block in section.blocks %}
            <div style="padding:2.5rem;{% if section_data.dark_theme | default: section.settings.dark_theme %}background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);{% else %}background:rgba(0,0,0,0.02);border:1px solid var(--color-warm-gray);{% endif %}" {{ block.shopify_attributes }}>
              <div class="text-eyebrow" style="margin-bottom:1rem;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.3);{% endif %}">{{ block.settings.title }}</div>
              <p style="font-size:0.9375rem;line-height:1.7;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.5);{% else %}color:var(--color-dark-gray);{% endif %};">{{ block.settings.description }}</p>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "Page card list",
  "settings": [
    { "type": "page", "id": "page", "label": "Display on page" },
    { "type": "checkbox", "id": "dark_theme", "label": "Use dark theme", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "html", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p></p>" },
    { "type": "text", "id": "kicker", "label": "Kicker" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Training Systems" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Structured systems built for discipline, presence, and consistency." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Page card list",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
