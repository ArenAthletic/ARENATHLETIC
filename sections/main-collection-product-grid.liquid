{% liquid
  assign cc_page = shop.metafields.cloudcannon.pages['collection'].value
  assign collection_grid = blank

  if cc_page and cc_page.collection_grid != blank
    assign collection_grid = cc_page.collection_grid
  endif
%}

<div data-editable="component" data-component="collection-grid" data-path="sections/main-collection-product-grid.liquid" data-key="collection_grid">
  <section style="padding-top:calc(68px + var(--space-lg));padding-bottom:var(--space-lg);border-bottom:1px solid var(--color-warm-gray);" data-editable="source" data-path="data/pages/collection.json" data-key="collection_grid">
    <div class="container">
      <h1 style="font-family:var(--font-display);font-size:clamp(2.5rem,6vw,5.5rem);font-weight:700;letter-spacing:-0.01em;line-height:0.95;text-transform:uppercase;margin-bottom:1.5rem;" data-editable="text" data-prop="collection_grid.hero_heading">{{ collection_grid.hero_heading | default: 'COMPOSURE UNDER PRESSURE.' }}</h1>
      <p class="text-body" style="max-width:52ch;" data-editable="text" data-prop="collection_grid.hero_copy">{{ collection_grid.hero_copy | default: 'Performance-informed apparel built for daily standards, not trends.' }}</p>
    </div>
  </section>

  <section style="padding:3rem 0;border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="text-eyebrow" style="text-align:center;margin-bottom:2rem;" data-editable="text" data-prop="collection_grid.philosophy_eyebrow">{{ collection_grid.philosophy_eyebrow | default: 'Design Philosophy' }}</div>
      <h2 style="font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,3.2rem);font-weight:700;letter-spacing:-0.01em;text-transform:uppercase;line-height:0.95;text-align:center;margin-bottom:3rem;" data-editable="text" data-prop="collection_grid.philosophy_heading">{{ collection_grid.philosophy_heading | default: 'FUNCTION. RESTRAINT. DURABILITY.' }}</h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--color-warm-gray);" data-editable="array" data-prop="collection_grid.philosophy_columns">
        {% if collection_grid.philosophy_columns != blank %}
          {% for column in collection_grid.philosophy_columns %}
            <div style="padding:2.5rem 2rem;{% unless forloop.last %}border-right:1px solid var(--color-warm-gray);{% endunless %}" data-editable="array-item" data-prop="collection_grid.philosophy_columns[{{ forloop.index0 }}]">
              <div class="text-eyebrow" style="margin-bottom:0.75rem;" data-editable="text" data-prop="collection_grid.philosophy_columns[{{ forloop.index0 }}].title">{{ column.title }}</div>
              <p class="text-body-sm" data-editable="text" data-prop="collection_grid.philosophy_columns[{{ forloop.index0 }}].description">{{ column.description }}</p>
            </div>
          {% endfor %}
        {% else %}
          <div style="padding:2.5rem 2rem;border-right:1px solid var(--color-warm-gray);"><div class="text-eyebrow" style="margin-bottom:0.75rem;">Training</div><p class="text-body-sm">Engineered for high-output training environments.</p></div>
          <div style="padding:2.5rem 2rem;border-right:1px solid var(--color-warm-gray);"><div class="text-eyebrow" style="margin-bottom:0.75rem;">Daily Wear</div><p class="text-body-sm">Structured comfort for transition and recovery days.</p></div>
          <div style="padding:2.5rem 2rem;"><div class="text-eyebrow" style="margin-bottom:0.75rem;">Outer Layers</div><p class="text-body-sm">Technical protection for environmental defense.</p></div>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="shop-filter-bar">
    <div class="container">
      <div class="shop-filters" data-editable="array" data-prop="collection_grid.filters">
        {% if collection_grid.filters != blank %}
          {% for filter in collection_grid.filters %}
            <span class="shop-filter{% if forloop.first %} active{% endif %}" data-filter="{{ filter | handle }}" data-editable="array-item" data-prop="collection_grid.filters[{{ forloop.index0 }}]">{{ filter }}</span>
          {% endfor %}
        {% else %}
          <span class="shop-filter active" data-filter="all">Shop System</span>
          <span class="shop-filter" data-filter="new">New Arrivals</span>
          <span class="shop-filter" data-filter="core">Core Essentials</span>
          <span class="shop-filter" data-filter="outerwear">Outerwear</span>
          <span class="shop-filter" data-filter="accessories">Accessories</span>
        {% endif %}
      </div>
    </div>
  </div>

  <section class="shop-grid">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3rem;padding-bottom:1.5rem;border-bottom:1px solid var(--color-warm-gray);">
        <div class="text-eyebrow" data-editable="text" data-prop="collection_grid.all_pieces_label">{{ collection_grid.all_pieces_label | default: 'All Pieces' }}</div>
        <div class="text-eyebrow" style="color:var(--color-black);" data-editable="text" data-prop="collection_grid.current_collection_label">{{ collection_grid.current_collection_label | default: 'Current Collection' }}</div>
      </div>

      <div class="shop-product-grid" data-editable="array" data-prop="collection_grid.fallback_cards">
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="product-card" style="text-decoration:none;color:inherit;">
            <div class="product-image" style="background:#f2efe9;">
              {% if product.featured_image %}
                <img class="product-img" src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy">
              {% endif %}
              {% if product.tags.size > 0 %}
                <div class="product-tag">{{ product.tags.first }}</div>
              {% endif %}
            </div>
            <div class="product-name">{{ product.title }}</div>
            {% if product.description != blank %}
              <div class="product-desc">{{ product.description | strip_html | truncate: 60 }}</div>
            {% endif %}
            <div class="product-price">{{ product.price | money }}</div>
          </a>
        {% else %}
          {% if collection_grid.fallback_cards != blank %}
            {% for card in collection_grid.fallback_cards %}
              <a href="{{ card.link | default: '#' }}" class="product-card" style="text-decoration:none;color:inherit;" data-editable="array-item" data-prop="collection_grid.fallback_cards[{{ forloop.index0 }}]">
                <div class="product-image" style="background:{{ card.background_color | default: '#1e1e1c' }};">
                  {% if card.image != blank %}
                    <img class="product-img" src="{{ card.image }}" alt="{{ card.image_alt | default: card.title | escape }}" title="{{ card.image_title | escape }}" loading="lazy" data-editable="image" data-prop-src="collection_grid.fallback_cards[{{ forloop.index0 }}].image" data-prop-alt="collection_grid.fallback_cards[{{ forloop.index0 }}].image_alt" data-prop-title="collection_grid.fallback_cards[{{ forloop.index0 }}].image_title">
                  {% endif %}
                </div>
                <div class="product-name" data-editable="text" data-prop="collection_grid.fallback_cards[{{ forloop.index0 }}].title">{{ card.title }}</div>
                <div class="product-desc" data-editable="text" data-prop="collection_grid.fallback_cards[{{ forloop.index0 }}].description">{{ card.description }}</div>
                <div class="product-price" data-editable="text" data-prop="collection_grid.fallback_cards[{{ forloop.index0 }}].price_label">{{ card.price_label }}</div>
              </a>
            {% endfor %}
          {% else %}
            <a href="#" class="product-card" style="text-decoration:none;color:inherit;" data-editable="array-item" data-prop="collection_grid.fallback_cards[0]">
              <div class="product-image" style="background:#1e1e1c;">
                <img class="product-img" src="https://static.wixstatic.com/media/8a3301_e81c756c4aaa4045ba6b10d2aeb788d6~mv2.png/v1/fill/w_480,h_640,al_c,q_85,enc_auto/8a3301_e81c756c4aaa4045ba6b10d2aeb788d6~mv2.png" alt="AREN Athletic Boxy Tee — Black" loading="lazy">
              </div>
              <div class="product-name" data-editable="text" data-prop="collection_grid.empty_title">{{ collection_grid.empty_title | default: 'Add Shopify products' }}</div>
              <div class="product-desc" data-editable="text" data-prop="collection_grid.empty_description">{{ collection_grid.empty_description | default: 'This layout is ready for your real catalog.' }}</div>
              <div class="product-price" data-editable="text" data-prop="collection_grid.empty_price">{{ collection_grid.empty_price | default: 'Theme Ready' }}</div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section style="background:var(--color-black);padding:var(--space-xl) 0;margin-top:var(--space-lg);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:center;">
        <div>
          <div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:2rem;" data-editable="text" data-prop="collection_grid.why_eyebrow">{{ collection_grid.why_eyebrow | default: 'Why AREN Apparel' }}</div>
          <h2 style="font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,3.2rem);font-weight:700;color:#fff;line-height:0.95;letter-spacing:-0.01em;text-transform:uppercase;margin-bottom:1.75rem;" data-editable="text" data-prop="collection_grid.why_heading">{{ collection_grid.why_heading | default: 'NOT STREETWEAR.<br>A SYSTEM.' }}</h2>
          <div data-editable="array" data-prop="collection_grid.why_paragraphs">
            {% if collection_grid.why_paragraphs != blank %}
              {% for paragraph in collection_grid.why_paragraphs %}
                <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:44ch;{% if forloop.last %}margin-bottom:2rem;{% else %}margin-bottom:1.5rem;{% endif %}" data-editable="array-item" data-prop="collection_grid.why_paragraphs[{{ forloop.index0 }}]">{{ paragraph }}</p>
              {% endfor %}
            {% else %}
              <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:44ch;margin-bottom:1.5rem;">AREN apparel exists as an extension of the athlete's standard.</p>
              <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:44ch;margin-bottom:1.5rem;">Not driven by seasonal trends or streetwear cycles, but by discipline, restraint, and functional precision.</p>
              <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:44ch;margin-bottom:1.5rem;">Every piece is designed to hold up under training and carry that same standard into the rest of life.</p>
              <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:44ch;margin-bottom:2rem;">This is not clothing for spectators.</p>
            {% endif %}
          </div>
          <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.65);max-width:44ch;font-weight:500;" data-editable="text" data-prop="collection_grid.why_emphasis">{{ collection_grid.why_emphasis | default: "It's equipment for people who operate." }}</p>
        </div>
        <div style="border-left:1px solid rgba(255,255,255,0.08);padding-left:var(--space-xl);" data-editable="array" data-prop="collection_grid.meta_blocks">
          {% if collection_grid.meta_blocks != blank %}
            {% for block in collection_grid.meta_blocks %}
              <div style="{% unless forloop.last %}margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid rgba(255,255,255,0.08);{% endunless %}" data-editable="array-item" data-prop="collection_grid.meta_blocks[{{ forloop.index0 }}]">
                <div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:0.75rem;" data-editable="text" data-prop="collection_grid.meta_blocks[{{ forloop.index0 }}].title">{{ block.title }}</div>
                <p style="font-size:0.875rem;color:rgba(255,255,255,0.5);" data-editable="text" data-prop="collection_grid.meta_blocks[{{ forloop.index0 }}].description">{{ block.description }}</p>
              </div>
            {% endfor %}
          {% else %}
            <div style="margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid rgba(255,255,255,0.08);"><div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:0.75rem;">Shipping</div><p style="font-size:0.875rem;color:rgba(255,255,255,0.5);">Shipping nationwide on all orders.</p></div>
            <div style="margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid rgba(255,255,255,0.08);"><div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:0.75rem;">Quality Standard</div><p style="font-size:0.875rem;color:rgba(255,255,255,0.5);">Built to last. Every piece carries the AREN standard.</p></div>
            <div><div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:0.75rem;">Returns</div><p style="font-size:0.875rem;color:rgba(255,255,255,0.5);">30-day return policy on unworn items.</p></div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Main collection product grid",
  "settings": [],
  "presets": [
    {
      "name": "Main collection product grid"
    }
  ]
}
{% endschema %}
