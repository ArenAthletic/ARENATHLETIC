<section class="section" style="padding-top:calc(68px + var(--space-lg));">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="text-eyebrow mb-sm">Account</div>
        <h1 class="text-h2">Welcome back</h1>
      </div>
      <a href="{{ routes.account_logout_url }}" class="btn btn--outline">Log out</a>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow" style="margin-bottom:1rem;">Orders</div>
        {% if customer.orders.size > 0 %}
          {% for order in customer.orders %}
            <div style="padding:1.5rem 0;border-top:1px solid var(--color-warm-gray);">
              <a href="{{ order.customer_url }}" class="product-name" style="display:block;margin-bottom:0.5rem;">{{ order.name }}</a>
              <div class="text-body-sm">{{ order.created_at | date: '%b %d, %Y' }} • {{ order.financial_status_label }} • {{ order.fulfillment_status_label }}</div>
            </div>
          {% endfor %}
        {% else %}
          <p class="text-body">No orders yet.</p>
        {% endif %}
      </div>
      <div>
        <div class="text-eyebrow" style="margin-bottom:1rem;">Default address</div>
        <div class="text-body">{{ customer.default_address | format_address }}</div>
        <div style="margin-top:1.5rem;">
          <a href="{{ routes.account_addresses_url }}" class="btn btn--outline">Manage addresses</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main customers account",
  "settings": [],
  "presets": [
    {
      "name": "Main customers account"
    }
  ]
}
{% endschema %}
