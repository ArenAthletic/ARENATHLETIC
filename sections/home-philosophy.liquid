{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
%}

<section class="section" style="background:var(--color-black);color:var(--color-white);">
  <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:start;">
    <div>
      {% if section.settings.eyebrow != blank %}<div class="text-eyebrow mb-sm" style="color:rgba(255,255,255,0.3);">{{ section.settings.eyebrow }}</div>{% endif %}
      {% if section.settings.heading != blank %}<h2 class="text-h2" style="margin-bottom:1.5rem;color:#fff;">{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.copy != blank %}<div class="text-body rte" style="max-width:42ch;margin-bottom:2rem;color:rgba(255,255,255,0.6);">{{ section.settings.copy }}</div>{% endif %}
      {% if section.settings.button_label != blank %}<a href="{{ about_url }}" class="btn btn--outline-white">{{ section.settings.button_label }}</a>{% endif %}
    </div>
    <div class="training-grid" style="grid-template-columns:1fr;gap:1rem;">
      {% for block in section.blocks %}
        <div class="training-card" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.08);" {{ block.shopify_attributes }}>
          <div class="training-card-number" style="color:#fff;">{{ block.settings.value }}</div>
          <div class="training-card-title" style="color:#fff;">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home philosophy",
  "settings": [
    { "type": "page", "id": "about_page", "label": "About page" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Brand Philosophy" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "The standard is the standard." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>AREN is built on discipline, presence, and consistency — apparel designed to perform in training and carry the standard everywhere else in life.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "About AREN" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Philosophy stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "NYC" },
        { "type": "text", "id": "label", "label": "Label", "default": "Home Chapter — Five Boroughs" }
      ]
    }
  ],
  "presets": [{ "name": "Home philosophy", "blocks": [{ "type": "stat" }, { "type": "stat" }, { "type": "stat" }] }]
}
{% endschema %}
