{% render 'cc-structured-data' %}
{% liquid
  assign ticker = blank
  if cc_page and cc_page.announcement_ticker != blank
    assign ticker = cc_page.announcement_ticker
  endif
%}

{% if ticker != blank and ticker.text != blank %}
  <div class="marquee-strip" {{ section.shopify_attributes }}>
    <div class="marquee-track">
      <span class="marquee-text" data-editable="text" data-prop="announcement_ticker.text">{{ ticker.text }}</span>
      <span class="marquee-text" data-editable="text" data-prop="announcement_ticker.text">{{ ticker.text }}</span>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement ticker",
  "settings": [],
  "presets": [{ "name": "Announcement ticker" }]
}
{% endschema %}
