{% liquid
  assign target_page = section.settings.page
  assign current_page_handle = page.handle | default: handle
  assign target_page_handle = blank
  assign page_data = blank
  assign section_data = blank
  assign section_key = blank

  if target_page != blank
    assign target_page_handle = target_page.handle
  endif

  if target_page_handle != blank and target_page_handle != current_page_handle
    break
  endif

  assign section_key = section.id | split: '__' | first | replace: '-', '_'

  if shop.metafields.cloudcannon.pages[current_page_handle] != blank
    assign page_data = shop.metafields.cloudcannon.pages[current_page_handle].value
  endif

  if page_data != blank and page_data[section_key] != blank
    assign section_data = page_data[section_key]
  elsif page_data != blank and page_data.hero != blank
    assign section_data = page_data.hero
  endif
%}

<div data-editable="component" data-component="page-hero-banner" data-path="sections/page-hero-banner.liquid" data-key="{{ section_key }}">
<section class="page-hero{% if section_data.dark_theme | default: section.settings.dark_theme %} page-hero--dark{% endif %}" style="position:relative;overflow:hidden;min-height:{{ section_data.min_height | default: section.settings.min_height }}px;display:flex;align-items:flex-end;" data-editable="source" data-path="data/pages/{{ current_page_handle }}.json" data-key="{{ section_key }}">
  <div data-editable="image" data-prop-src="{{ section_key }}.background_image" data-prop-alt="{{ section_key }}.image_alt" data-prop-title="{{ section_key }}.image_title" style="position:absolute;inset:0;{% if section_data.background_image != blank %}background-image:url('{{ section_data.background_image }}');{% elsif section.settings.background_image != blank %}background-image:url('{{ section.settings.background_image | image_url: width: 2200 }}');{% elsif section_data.fallback_image_url != blank %}background-image:url('{{ section_data.fallback_image_url }}');{% elsif section.settings.fallback_image_url != blank %}background-image:url('{{ section.settings.fallback_image_url }}');{% endif %}background-size:cover;background-position:{{ section_data.background_position | default: section.settings.background_position }};"></div>
  <div style="position:absolute;inset:0;background:{{ section_data.overlay_gradient | default: section.settings.overlay_gradient }};"></div>
  <div class="container" style="position:relative;z-index:1;padding-bottom:var(--space-xl);">
    {% if section_data.eyebrow != blank or section.settings.eyebrow != blank %}
      <div class="text-eyebrow" data-editable="text" data-prop="{{ section_key }}.eyebrow" style="margin-bottom:2rem;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.35);{% endif %}">{{ section_data.eyebrow | default: section.settings.eyebrow }}</div>
    {% endif %}
    {% if section_data.heading != blank or section.settings.heading != blank %}
      <h1 class="text-display" data-editable="text" data-prop="{{ section_key }}.heading" style="{% if section_data.dark_theme | default: section.settings.dark_theme %}color:#fff;{% endif %}max-width:{{ section_data.heading_width | default: section.settings.heading_width }}ch;margin-bottom:{% if section_data.copy != blank or section.settings.copy != blank %}2rem{% else %}0{% endif %};">{{ section_data.heading | default: section.settings.heading }}</h1>
    {% endif %}
    {% if section_data.copy != blank or section.settings.copy != blank %}
      <div class="text-body rte" data-editable="text" data-prop="{{ section_key }}.copy" style="max-width:{{ section_data.copy_width | default: section.settings.copy_width }}ch;{% if section_data.dark_theme | default: section.settings.dark_theme %}color:rgba(255,255,255,0.6);{% endif %}">{{ section_data.copy | default: section.settings.copy }}</div>
    {% endif %}
  </div>
</section>
</div>

{% schema %}
{
  "name": "Page hero banner",
  "settings": [
    { "type": "page", "id": "page", "label": "Display on page" },
    { "type": "checkbox", "id": "dark_theme", "label": "Use dark theme", "default": true },
    { "type": "range", "id": "min_height", "label": "Minimum height", "min": 320, "max": 900, "step": 20, "unit": "px", "default": 480 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About AREN" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "AREN isn't just apparel. AREN is a standard." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p></p>" },
    { "type": "range", "id": "heading_width", "label": "Heading width", "min": 8, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "copy_width", "label": "Copy width", "min": 20, "max": 70, "step": 1, "default": 46 },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "fallback_image_url", "label": "Fallback image URL" },
    { "type": "select", "id": "background_position", "label": "Background position", "default": "center", "options": [
      { "value": "center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ]},
    { "type": "textarea", "id": "overlay_gradient", "label": "Overlay gradient", "default": "linear-gradient(165deg,rgba(28,28,26,0.88) 0%,rgba(35,35,33,0.68) 55%,rgba(26,26,24,0.92) 100%)" }
  ],
  "presets": [
    { "name": "Page hero banner" }
  ]
}
{% endschema %}
