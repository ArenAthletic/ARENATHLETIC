{% render 'cc-structured-data' %}
{% liquid
  assign cc_hero = blank

  if cc_page and cc_page.hero != blank
    assign cc_hero = cc_page.hero
  endif

  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign contact_url = pages['contact'].url | default: '/pages/contact'

  if cc_hero.shop_url != blank
    assign shop_url = cc_hero.shop_url
  elsif section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif

  if cc_hero.contact_url != blank
    assign contact_url = cc_hero.contact_url
  elsif section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
%}

<section class="page-hero page-hero--dark" style="position:relative;overflow:hidden;min-height:{{ cc_hero.min_height | default: section.settings.min_height }}px;display:flex;align-items:flex-end;">
  <div data-editable="image" data-prop="hero.background_image" style="position:absolute;inset:0;{% if cc_hero.background_image != blank %}background-image:url('{{ cc_hero.background_image }}');{% elsif section.settings.background_image != blank %}background-image:url('{{ section.settings.background_image | image_url: width: 2200 }}');{% elsif settings.default_hero_image != blank %}background-image:url('{{ settings.default_hero_image | image_url: width: 2200 }}');{% elsif cc_hero.fallback_image_url != blank %}background-image:url('{{ cc_hero.fallback_image_url }}');{% elsif section.settings.fallback_image_url != blank %}background-image:url('{{ section.settings.fallback_image_url }}');{% endif %}background-size:cover;background-position:{{ cc_hero.background_position | default: section.settings.background_position }};"></div>
  <div style="position:absolute;inset:0;background:{{ cc_hero.overlay_gradient | default: section.settings.overlay_gradient }};"></div>
  <div class="container" style="position:relative;z-index:1;padding-bottom:var(--space-xl);">
    {% if cc_hero.eyebrow != blank or section.settings.eyebrow != blank %}
      <div class="text-eyebrow" style="margin-bottom:2rem;color:rgba(255,255,255,0.35);">{{ cc_hero.eyebrow | default: section.settings.eyebrow }}</div>
    {% endif %}
    {% if cc_hero.heading != blank or section.settings.heading != blank %}
      <h1 class="text-display" data-editable="text" data-prop="hero.heading" style="color:#fff;max-width:{{ cc_hero.heading_width | default: section.settings.heading_width }}ch;margin-bottom:1.5rem;">{{ cc_hero.heading | default: section.settings.heading }}</h1>
    {% endif %}
    {% if cc_hero.copy != blank or section.settings.copy != blank %}
      <div class="text-body rte" style="max-width:{{ cc_hero.copy_width | default: section.settings.copy_width }}ch;color:rgba(255,255,255,0.65);margin-bottom:2rem;">{{ cc_hero.copy | default: section.settings.copy }}</div>
    {% endif %}
    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem;">
      {% if cc_hero.primary_button_label != blank or section.settings.primary_button_label != blank %}
        <a href="{{ shop_url }}" class="btn btn--primary">{{ cc_hero.primary_button_label | default: section.settings.primary_button_label }}</a>
      {% endif %}
      {% if cc_hero.secondary_button_label != blank or section.settings.secondary_button_label != blank %}
        <a href="{{ contact_url }}" class="btn btn--outline-white">{{ cc_hero.secondary_button_label | default: section.settings.secondary_button_label }}</a>
      {% endif %}
    </div>
    <div style="display:grid;gap:0.35rem;color:rgba(255,255,255,0.42);font-family:var(--font-mono);font-size:0.625rem;letter-spacing:0.18em;text-transform:uppercase;">
      {% if cc_hero.microcopy_one != blank or section.settings.microcopy_one != blank %}<span>{{ cc_hero.microcopy_one | default: section.settings.microcopy_one }}</span>{% endif %}
      {% if cc_hero.microcopy_two != blank or section.settings.microcopy_two != blank %}<span>{{ cc_hero.microcopy_two | default: section.settings.microcopy_two }}</span>{% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "page", "id": "shop_page", "label": "Shop page" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "range", "id": "min_height", "label": "Minimum height", "min": 420, "max": 900, "step": 20, "unit": "px", "default": 640 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "AREN ATHLETIC" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Apparel built for training—and everything after." },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>Minimal. Durable. Elevated. Designed for the gym, the street, and the pace of New York.</p>" },
    { "type": "text", "id": "primary_button_label", "label": "Primary button label", "default": "Shop Apparel" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button label", "default": "Join the Community" },
    { "type": "text", "id": "microcopy_one", "label": "Microcopy line 1", "default": "New drops + core staples • Shipping nationwide" },
    { "type": "text", "id": "microcopy_two", "label": "Microcopy line 2", "default": "Quiet confidence. Built to wear daily." },
    { "type": "range", "id": "heading_width", "label": "Heading width", "min": 8, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "copy_width", "label": "Copy width", "min": 20, "max": 70, "step": 1, "default": 44 },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "fallback_image_url", "label": "Fallback image URL" },
    { "type": "select", "id": "background_position", "label": "Background position", "default": "center", "options": [
      { "value": "center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ]},
    { "type": "textarea", "id": "overlay_gradient", "label": "Overlay gradient", "default": "linear-gradient(165deg,rgba(28,28,26,0.88) 0%,rgba(35,35,33,0.68) 55%,rgba(26,26,24,0.92) 100%)" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
