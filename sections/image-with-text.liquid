{% liquid
  assign section_classes = 'image-with-text'
  if section.settings.dark_theme
    assign section_classes = section_classes | append: ' image-with-text--dark'
  endif

  assign button_url = blank
  if section.settings.button_link != blank
    assign button_url = section.settings.button_link
  elsif section.settings.page_link != blank
    assign button_url = section.settings.page_link.url
  endif
%}

<section class="{{ section_classes }}" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="image-with-text__grid"{% if section.settings.image_position == 'right' %} style="direction:rtl;"{% endif %}>
      <div class="media-card"{% if section.settings.image_position == 'right' %} style="direction:ltr;"{% endif %}>
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1600 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            loading="lazy"
          >
        {% elsif settings.default_hero_image != blank %}
          <img
            src="{{ settings.default_hero_image | image_url: width: 1600 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="image-with-text__content"{% if section.settings.image_position == 'right' %} style="direction:ltr;"{% endif %}>
        {% if section.settings.eyebrow != blank %}
          <div class="text-eyebrow">{{ section.settings.eyebrow }}</div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="text-h2">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="text-body rte">{{ section.settings.text }}</div>
        {% endif %}

        {% if button_url != blank and section.settings.button_label != blank %}
          <div>
            <a href="{{ button_url }}" class="btn {% if section.settings.dark_theme %}btn--outline-white{% else %}btn--outline{% endif %}">{{ section.settings.button_label }}</a>
          </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="image-with-text__stats">
            {% for block in section.blocks %}
              <div class="image-with-text__stat" {{ block.shopify_attributes }}>
                {% if block.settings.value != blank %}
                  <div class="text-display" style="font-size:clamp(1.6rem,3vw,3rem);">{{ block.settings.value }}</div>
                {% endif %}
                {% if block.settings.label != blank %}
                  <div class="text-eyebrow">{{ block.settings.label }}</div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "checkbox", "id": "dark_theme", "label": "Enable dark theme", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Brand Philosophy" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "The standard is the standard." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>AREN exists as an extension of the athlete's standard—built for discipline, consistency, and everyday performance.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" }
    ] },
    { "type": "page", "id": "page_link", "label": "Page link" },
    { "type": "url", "id": "button_link", "label": "Custom button link" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "NYC" },
        { "type": "text", "id": "label", "label": "Label", "default": "Home Chapter — Five Boroughs" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        { "type": "stat" },
        { "type": "stat", "settings": { "value": "Daily", "label": "Standard — Not Seasonal" } },
        { "type": "stat", "settings": { "value": "One", "label": "System — Built to Perform" } }
      ]
    }
  ]
}
{% endschema %}
