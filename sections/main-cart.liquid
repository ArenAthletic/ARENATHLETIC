<section class="section" style="padding-top:calc(68px + var(--space-lg));">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="text-eyebrow mb-sm">Cart</div>
        <h1 class="text-h2">Your system</h1>
      </div>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div style="display:grid;grid-template-columns:1.4fr 0.8fr;gap:var(--space-xl);align-items:start;">
          <div>
            {% for item in cart.items %}
              <div style="display:grid;grid-template-columns:120px 1fr auto;gap:1rem;align-items:center;padding:1.5rem 0;border-bottom:1px solid var(--color-warm-gray);">
                <a href="{{ item.url }}" class="product-image" style="aspect-ratio:3/4;background:#f2efe9;margin-bottom:0;">
                  {% if item.image %}
                    {{ item.image | image_url: width: 400 | image_tag: class: 'product-img', loading: 'lazy', alt: item.product.title }}
                  {% endif %}
                </a>
                <div>
                  <a href="{{ item.url }}" class="product-name" style="display:block;margin-bottom:0.5rem;">{{ item.product.title }}</a>
                  {% if item.variant.title != 'Default Title' %}
                    <div class="product-desc">{{ item.variant.title }}</div>
                  {% endif %}
                  <div class="text-body-sm">{{ item.final_price | money }}</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.75rem;align-items:flex-end;">
                  <input class="form-input" style="width:88px;" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                  <a href="{{ item.url_to_remove }}" class="text-eyebrow">Remove</a>
                </div>
              </div>
            {% endfor %}
          </div>
          <div style="padding:2rem;border:1px solid var(--color-warm-gray);">
            <div class="text-eyebrow" style="margin-bottom:1rem;">Summary</div>
            <div class="text-body" style="display:flex;justify-content:space-between;margin-bottom:1rem;"><span>Subtotal</span><span>{{ cart.total_price | money }}</span></div>
            <p class="text-body-sm" style="margin-bottom:1.5rem;">Taxes and shipping calculated at checkout.</p>
            <button class="btn btn--outline" type="submit" name="update">Update cart</button>
            <button class="btn btn--primary" type="submit" name="checkout" style="margin-top:0.75rem;">Checkout</button>
          </div>
        </div>
      </form>
    {% else %}
      <div style="padding:3rem 0;border-top:1px solid var(--color-warm-gray);">
        <p class="text-body" style="margin-bottom:1.5rem;">Your cart is empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Shop Apparel</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": [],
  "presets": [
    {
      "name": "Main cart"
    }
  ]
}
{% endschema %}
