{% liquid
  assign target_page = section.settings.page
  assign current_page_handle = page.handle | default: handle
  assign target_page_handle = blank
  assign page_data = blank
  assign section_data = blank
  assign section_key = section.id | split: '__' | first | replace: '-', '_'
  assign button_url = section.settings.button_url
  if target_page != blank
    assign target_page_handle = target_page.handle
  endif
  if target_page_handle != blank and target_page_handle != current_page_handle
    break
  endif
  if shop.metafields.cloudcannon.pages[current_page_handle] != blank
    assign page_data = shop.metafields.cloudcannon.pages[current_page_handle].value
  endif
  if page_data != blank and page_data[section_key] != blank
    assign section_data = page_data[section_key]
  endif
  if section_data.button_url != blank
    assign button_url = section_data.button_url
  endif
%}

<div data-editable="component" data-component="page-split-content" data-path="sections/page-split-content.liquid" data-key="{{ section_key }}">
<section class="section" style="{% if section_data.border_top | default: section.settings.border_top %}border-top:1px solid var(--color-warm-gray);{% endif %}{% if section_data.border_bottom | default: section.settings.border_bottom %}border-bottom:1px solid var(--color-warm-gray);{% endif %}{% if section_data.section_background | default: section.settings.section_background == 'dark' %}background:var(--color-black);color:var(--color-white);{% endif %}" data-editable="source" data-path="data/pages/{{ current_page_handle }}.json" data-key="{{ section_key }}">
  <div class="container{% if section_data.narrow | default: section.settings.narrow %} container--narrow{% endif %}">
    <div style="display:grid;grid-template-columns:{{ section_data.columns | default: section.settings.columns }};gap:var(--space-xl);align-items:{{ section_data.vertical_align | default: section.settings.vertical_align }};">
      <div>
        {% if section_data.eyebrow != blank or section.settings.eyebrow != blank %}
          <div class="text-eyebrow" data-editable="text" data-prop="{{ section_key }}.eyebrow" style="margin-bottom:2rem;{% if section_data.section_background | default: section.settings.section_background == 'dark' %}color:rgba(255,255,255,0.3);{% endif %}">{{ section_data.eyebrow | default: section.settings.eyebrow }}</div>
        {% endif %}
        {% if section_data.heading != blank or section.settings.heading != blank %}
          <h2 class="text-h2" data-editable="text" data-prop="{{ section_key }}.heading" style="max-width:{{ section_data.heading_width | default: section.settings.heading_width }}ch;margin-bottom:1.75rem;{% if section_data.section_background | default: section.settings.section_background == 'dark' %}color:#fff;{% endif %}">{{ section_data.heading | default: section.settings.heading }}</h2>
        {% endif %}
        {% if section_data.copy != blank or section.settings.copy != blank %}
          <div class="text-body rte" data-editable="text" data-prop="{{ section_key }}.copy" style="{% if section_data.section_background | default: section.settings.section_background == 'dark' %}color:rgba(255,255,255,0.6);{% endif %}">{{ section_data.copy | default: section.settings.copy }}</div>
        {% endif %}
        {% if section_data.kicker != blank or section.settings.kicker != blank %}
          <p style="font-family:var(--font-mono);font-size:0.625rem;letter-spacing:0.2em;text-transform:uppercase;{% if section_data.section_background | default: section.settings.section_background == 'dark' %}color:rgba(255,255,255,0.35);{% else %}color:var(--color-mid-gray);{% endif %};margin-top:1rem;" data-editable="text" data-prop="{{ section_key }}.kicker">{{ section_data.kicker | default: section.settings.kicker }}</p>
        {% endif %}
        {% if section_data.button_label != blank or section.settings.button_label != blank and button_url != blank %}
          <div style="margin-top:2rem;"><a href="{{ button_url }}" class="btn {% if section_data.button_style | default: section.settings.button_style == 'primary' %}btn--primary{% elsif section_data.button_style | default: section.settings.button_style == 'outline-white' %}btn--outline-white{% else %}btn--outline{% endif %}" data-editable="text" data-prop="{{ section_key }}.button_label">{{ section_data.button_label | default: section.settings.button_label }}</a></div>
        {% endif %}
      </div>
      <div>
        {% if section_data.image != blank or section.settings.image != blank or section_data.fallback_image_url != blank or section.settings.fallback_image_url != blank %}
          <div style="position:relative;overflow:hidden;aspect-ratio:{{ section_data.image_aspect | default: section.settings.image_aspect }};">
            {% if section_data.image != blank %}
              <img src="{{ section_data.image }}" alt="{{ section_data.image_alt | default: section_data.heading | escape }}" title="{{ section_data.image_title | escape }}" data-editable="image" data-prop-src="{{ section_key }}.image" data-prop-alt="{{ section_key }}.image_alt" data-prop-title="{{ section_key }}.image_title" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
            {% elsif section.settings.image != blank %}
              <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
            {% elsif section_data.fallback_image_url != blank %}
              <img src="{{ section_data.fallback_image_url }}" alt="{{ section_data.heading | default: section.settings.heading | escape }}" title="{{ section_data.image_title | escape }}" data-editable="image" data-prop-src="{{ section_key }}.fallback_image_url" data-prop-alt="{{ section_key }}.image_alt" data-prop-title="{{ section_key }}.image_title" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
            {% elsif section.settings.fallback_image_url != blank %}
              <img src="{{ section.settings.fallback_image_url }}" alt="{{ section.settings.heading | escape }}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
            {% endif %}
            {% if section_data.image_overlay | default: section.settings.image_overlay %}
              <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(35,35,33,0.35) 0%,transparent 40%);"></div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "Page split content",
  "settings": [
    { "type": "page", "id": "page", "label": "Display on page" },
    { "type": "checkbox", "id": "border_top", "label": "Show top border", "default": false },
    { "type": "checkbox", "id": "border_bottom", "label": "Show bottom border", "default": true },
    { "type": "checkbox", "id": "narrow", "label": "Use narrow container", "default": false },
    { "type": "select", "id": "section_background", "label": "Background", "default": "light", "options": [
      { "value": "light", "label": "Light" },
      { "value": "dark", "label": "Dark" }
    ]},
    { "type": "select", "id": "columns", "label": "Columns", "default": "1fr 1fr", "options": [
      { "value": "1fr 1fr", "label": "50 / 50" },
      { "value": "1.1fr 0.9fr", "label": "55 / 45" },
      { "value": "0.9fr 1.1fr", "label": "45 / 55" }
    ]},
    { "type": "select", "id": "vertical_align", "label": "Vertical align", "default": "start", "options": [
      { "value": "start", "label": "Top" },
      { "value": "center", "label": "Center" },
      { "value": "end", "label": "Bottom" }
    ]},
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "html", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p></p>" },
    { "type": "text", "id": "kicker", "label": "Kicker" },
    { "type": "range", "id": "heading_width", "label": "Heading width", "min": 8, "max": 30, "step": 1, "default": 18 },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image_url", "label": "Fallback image URL" },
    { "type": "text", "id": "image_aspect", "label": "Image aspect ratio", "default": "3/4" },
    { "type": "checkbox", "id": "image_overlay", "label": "Add image overlay", "default": false },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "select", "id": "button_style", "label": "Button style", "default": "outline", "options": [
      { "value": "primary", "label": "Primary" },
      { "value": "outline", "label": "Outline" },
      { "value": "outline-white", "label": "Outline white" }
    ]}
  ],
  "presets": [
    { "name": "Page split content" }
  ]
}
{% endschema %}
