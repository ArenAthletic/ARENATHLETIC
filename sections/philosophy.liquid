{% render 'cc-structured-data' %}
{% liquid
  assign data = blank
  if cc_page and cc_page.philosophy != blank
    assign data = cc_page.philosophy
  endif
%}

{% if data != blank %}
<section class="section" style="background:var(--color-black);color:var(--color-white);" {{ section.shopify_attributes }}>
  <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:start;">
    <div>
      {% if data.eyebrow != blank %}<div class="text-eyebrow mb-sm" style="color:rgba(255,255,255,0.3);">{{ data.eyebrow }}</div>{% endif %}
      {% if data.heading != blank %}<h2 class="text-h2" style="margin-bottom:1.5rem;color:#fff;">{{ data.heading }}</h2>{% endif %}
      {% if data.copy != blank %}<div class="text-body rte" style="max-width:42ch;margin-bottom:2rem;color:rgba(255,255,255,0.6);">{{ data.copy }}</div>{% endif %}
      {% if data.button_label != blank %}<a href="{{ data.button_url | default: '/pages/about' }}" class="btn btn--outline-white">{{ data.button_label }}</a>{% endif %}
    </div>
    <div class="training-grid" style="grid-template-columns:1fr;gap:1rem;">
      {% for item in data.stats %}
        <div class="training-card" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.08);">
          <div class="training-card-number" style="color:#fff;">{{ item.value }}</div>
          <div class="training-card-title" style="color:#fff;">{{ item.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Philosophy",
  "settings": [],
  "presets": [{ "name": "Philosophy" }]
}
{% endschema %}
