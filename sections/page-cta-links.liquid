{% liquid
  assign target_page = section.settings.page
  assign current_page_handle = page.handle | default: handle
  assign target_page_handle = blank
  assign page_data = blank
  assign section_data = blank
  assign section_key = section.id | split: '__' | first | replace: '-', '_'
  if target_page != blank
    assign target_page_handle = target_page.handle
  endif
  if target_page_handle != blank and target_page_handle != current_page_handle
    break
  endif
  if shop.metafields.cloudcannon.pages[current_page_handle] != blank
    assign page_data = shop.metafields.cloudcannon.pages[current_page_handle].value
  endif
  if page_data != blank and page_data[section_key] != blank
    assign section_data = page_data[section_key]
  endif
%}

<div data-editable="component" data-component="page-cta-links" data-path="sections/page-cta-links.liquid" data-key="{{ section_key }}">
<section class="section" data-editable="source" data-path="data/pages/{{ current_page_handle }}.json" data-key="{{ section_key }}">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:center;">
      <div>
        {% if section_data.eyebrow != blank or section.settings.eyebrow != blank %}
          <div class="text-eyebrow" data-editable="text" data-prop="{{ section_key }}.eyebrow" style="margin-bottom:2rem;">{{ section_data.eyebrow | default: section.settings.eyebrow }}</div>
        {% endif %}
        {% if section_data.heading != blank or section.settings.heading != blank %}
          <h2 class="text-h2" data-editable="text" data-prop="{{ section_key }}.heading" style="max-width:22ch;margin-bottom:1.75rem;">{{ section_data.heading | default: section.settings.heading }}</h2>
        {% endif %}
        {% if section_data.copy != blank or section.settings.copy != blank %}
          <div class="text-body rte" data-editable="text" data-prop="{{ section_key }}.copy" style="max-width:46ch;">{{ section_data.copy | default: section.settings.copy }}</div>
        {% endif %}
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;max-width:420px;justify-self:end;" data-editable="array" data-prop="{{ section_key }}.links">
        {% if section_data.links != blank %}
          {% for link in section_data.links %}
            {% if link.url != blank and link.label != blank %}
              <a href="{{ link.url }}" class="btn {% if link.style == 'primary' %}btn--primary{% else %}btn--outline{% endif %}" data-editable="array-item" data-prop="{{ section_key }}.links[{{ forloop.index0 }}]">
                <span data-editable="text" data-prop="{{ section_key }}.links[{{ forloop.index0 }}].label">{{ link.label }}</span>
              </a>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for block in section.blocks %}
            {% if block.settings.url != blank and block.settings.label != blank %}
              <a href="{{ block.settings.url }}" class="btn {% if block.settings.style == 'primary' %}btn--primary{% else %}btn--outline{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "Page CTA links",
  "settings": [
    { "type": "page", "id": "page", "label": "Display on page" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "html", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p></p>" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link button",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Contact / Join" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "select", "id": "style", "label": "Style", "default": "outline", "options": [
          { "value": "primary", "label": "Primary" },
          { "value": "outline", "label": "Outline" }
        ]}
      ]
    }
  ],
  "presets": [
    {
      "name": "Page CTA links",
      "blocks": [
        { "type": "link", "settings": { "label": "Primary link", "style": "primary" } },
        { "type": "link", "settings": { "label": "Secondary link", "style": "outline" } }
      ]
    }
  ]
}
{% endschema %}
