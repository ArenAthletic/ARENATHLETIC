<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a href="{{ routes.root_url }}" class="footer-brand-name footer-brand-link" aria-label="{{ shop.name }} home">
          {% if settings.logo != blank %}
            <img
              src="{{ settings.logo | image_url: width: 180 }}"
              alt="{{ shop.name | escape }}"
              class="footer-logo-image"
            >
          {% else %}
            <img src="{{ 'aren-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="footer-logo-image">
          {% endif %}
        </a>
        <div class="footer-brand-taglines">
          <span class="footer-brand-tagline">SMNYC: FIVE BOROUGH CHAPTER</span>
          <span class="footer-brand-tagline">DISCIPLINE AND PERFORMANCE.</span>
          <span class="footer-brand-tagline">AREN ATHLETIC UNIFORM.</span>
        </div>
        <div class="footer-social">
          <a href="{{ settings.instagram_url | default: 'https://www.instagram.com/arenathletic/' }}" class="footer-social-link">IG</a>
          <a href="{{ settings.twitter_url | default: 'https://x.com/' }}" class="footer-social-link">TW</a>
          <a href="{{ settings.youtube_url | default: 'https://www.youtube.com/' }}" class="footer-social-link">YT</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">ECOSYSTEM</div>
        <div class="footer-links">
          <a href="{{ pages['about'].url | default: '/pages/about' }}" class="footer-link">About AREN</a>
          <a href="{{ pages['training'].url | default: '/pages/training' }}" class="footer-link">Training</a>
          <a href="{{ pages['services'].url | default: '/pages/services' }}" class="footer-link">Services</a>
          <a href="{{ pages['street-miles'].url | default: '/pages/street-miles' }}" class="footer-link">Street Miles NYC</a>
          <a href="{{ pages['contact'].url | default: '/pages/contact' }}" class="footer-link">Join the Community</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">ACCESS</div>
        <div class="footer-links">
          <a href="{{ routes.all_products_collection_url }}" class="footer-link">Shop Apparel</a>
          <a href="{{ routes.all_products_collection_url }}" class="footer-link">New Arrivals</a>
          <a href="{{ routes.all_products_collection_url }}" class="footer-link">Core Essentials</a>
          <a href="{{ routes.all_products_collection_url }}" class="footer-link">Outerwear</a>
          <a href="{{ routes.account_login_url }}" class="footer-link">Log In</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">NATIONAL HUB NETWORK.</div>
        <div class="footer-links">
          <a href="mailto:{{ settings.email_address | default: 'info@arenathletic.com' }}" class="footer-link">{{ settings.email_address | default: 'INFO@ARENATHLETIC.COM' | upcase }}</a>
          <span class="footer-link" style="cursor:default;">AREN ATHLETIC COLLECTIVE.</span>
          <span class="footer-link" style="cursor:default;">STRUCTURED PERFORMANCE.</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-left">
        <span class="footer-identity-line">AREN ATHLETIC — NEW YORK CITY</span>
        <span class="footer-copyright">© 2026 AREN ATHLETIC. ALL RIGHTS RESERVED.</span>
      </div>
      <div style="display:flex;gap:2rem;">
        <a href="{{ pages['privacy'].url | default: '/pages/privacy' }}" class="footer-copyright" style="text-decoration:none;">PRIVACY</a>
        <a href="{{ pages['terms'].url | default: '/pages/terms' }}" class="footer-copyright" style="text-decoration:none;">TERMS</a>
      </div>
    </div>
  </div>
</footer>
