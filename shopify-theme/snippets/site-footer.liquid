{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign ecosystem_menu_handle = settings.footer_ecosystem_menu
  assign access_menu_handle = settings.footer_access_menu
  assign ecosystem_menu_links = blank
  assign access_menu_links = blank

  if ecosystem_menu_handle != blank and linklists[ecosystem_menu_handle] != blank
    assign ecosystem_menu_links = linklists[ecosystem_menu_handle].links
  endif

  if access_menu_handle != blank and linklists[access_menu_handle] != blank
    assign access_menu_links = linklists[access_menu_handle].links
  endif
%}

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a href="{{ routes.root_url }}" class="footer-brand-name footer-brand-link" aria-label="{{ shop.name }} home">
          {% if settings.logo != blank %}
            <img
              src="{{ settings.logo | image_url: width: 180 }}"
              alt="{{ shop.name | escape }}"
              class="footer-logo-image"
            >
          {% else %}
            <img src="{{ 'aren-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="footer-logo-image">
          {% endif %}
        </a>
        <div class="footer-brand-taglines">
          <span class="footer-brand-tagline">{{ settings.footer_tagline_1 | default: 'SMNYC: FIVE BOROUGH CHAPTER' }}</span>
          <span class="footer-brand-tagline">{{ settings.footer_tagline_2 | default: 'DISCIPLINE AND PERFORMANCE.' }}</span>
          <span class="footer-brand-tagline">{{ settings.footer_tagline_3 | default: 'AREN ATHLETIC UNIFORM.' }}</span>
        </div>
        <div class="footer-social">
          <a href="{{ settings.instagram_url | default: 'https://www.instagram.com/arenathletic/' }}" class="footer-social-link">IG</a>
          <a href="{{ settings.twitter_url | default: 'https://x.com/' }}" class="footer-social-link">TW</a>
          <a href="{{ settings.youtube_url | default: 'https://www.youtube.com/' }}" class="footer-social-link">YT</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">{{ settings.footer_ecosystem_heading | default: 'ECOSYSTEM' }}</div>
        <div class="footer-links">
          {% if ecosystem_menu_links != blank %}
            {% for link in ecosystem_menu_links %}
              <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
            {% endfor %}
          {% else %}
            <a href="{{ about_url }}" class="footer-link">{{ settings.header_about_label | default: 'About AREN' }}</a>
            <a href="{{ training_url }}" class="footer-link">{{ settings.header_training_label | default: 'Training' }}</a>
            <a href="{{ services_url }}" class="footer-link">{{ settings.header_services_label | default: 'Services' }}</a>
            <a href="{{ street_miles_url }}" class="footer-link">{{ settings.header_street_label | default: 'Street Miles NYC' }}</a>
            <a href="{{ contact_url }}" class="footer-link">{{ settings.footer_join_label | default: 'Join the Community' }}</a>
          {% endif %}
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">{{ settings.footer_access_heading | default: 'ACCESS' }}</div>
        <div class="footer-links">
          {% if access_menu_links != blank %}
            {% for link in access_menu_links %}
              <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
            {% endfor %}
          {% else %}
            <a href="{{ shop_url }}" class="footer-link">{{ settings.footer_shop_label | default: 'Shop Apparel' }}</a>
            <a href="{{ shop_url }}" class="footer-link">{{ settings.footer_new_arrivals_label | default: 'New Arrivals' }}</a>
            <a href="{{ shop_url }}" class="footer-link">{{ settings.footer_core_essentials_label | default: 'Core Essentials' }}</a>
            <a href="{{ shop_url }}" class="footer-link">{{ settings.footer_outerwear_label | default: 'Outerwear' }}</a>
            <a href="{{ routes.account_login_url }}" class="footer-link">{{ settings.footer_login_label | default: 'Log In' }}</a>
          {% endif %}
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">{{ settings.footer_network_heading | default: 'NATIONAL HUB NETWORK.' }}</div>
        <div class="footer-links">
          <a href="mailto:{{ settings.email_address | default: 'info@arenathletic.com' }}" class="footer-link">{{ settings.email_address | default: 'INFO@ARENATHLETIC.COM' | upcase }}</a>
          <span class="footer-link" style="cursor:default;">{{ settings.footer_network_line_1 | default: 'AREN ATHLETIC COLLECTIVE.' }}</span>
          <span class="footer-link" style="cursor:default;">{{ settings.footer_network_line_2 | default: 'STRUCTURED PERFORMANCE.' }}</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-left">
        <span class="footer-identity-line">{{ settings.footer_identity_line | default: 'AREN ATHLETIC — NEW YORK CITY' }}</span>
        <span class="footer-copyright">{{ settings.footer_copyright | default: '© 2026 AREN ATHLETIC. ALL RIGHTS RESERVED.' }}</span>
      </div>
      <div style="display:flex;gap:2rem;">
        <a href="{{ privacy_url }}" class="footer-copyright" style="text-decoration:none;">{{ settings.footer_privacy_label | default: 'PRIVACY' }}</a>
        <a href="{{ terms_url }}" class="footer-copyright" style="text-decoration:none;">{{ settings.footer_terms_label | default: 'TERMS' }}</a>
      </div>
    </div>
  </div>
</footer>
