<a href="{{ card_product.url }}" class="product-card" style="text-decoration:none;color:inherit;">
  <div class="product-image" style="background:{{ background | default: '#f2efe9' }};">
    {% if card_product.featured_image %}
      <img
        class="product-img"
        src="{{ card_product.featured_image | image_url: width: 900 }}"
        alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
        loading="lazy"
      >
    {% endif %}
    {% if card_product.tags.size > 0 %}
      <div class="product-tag">{{ card_product.tags.first }}</div>
    {% endif %}
  </div>
  <div class="product-name">{{ card_product.title }}</div>
  {% if card_product.description != blank %}
    <div class="product-desc">{{ card_product.description | strip_html | truncate: 60 }}</div>
  {% endif %}
  <div class="product-price">
    {% if card_product.price_varies %}
      From {{ card_product.price_min | money }}
    {% else %}
      {{ card_product.price | money }}
    {% endif %}
  </div>
</a>
