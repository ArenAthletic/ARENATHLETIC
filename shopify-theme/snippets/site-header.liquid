{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
%}

<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }} home">
      {% if settings.logo != blank %}
        <img
          src="{{ settings.logo | image_url: width: settings.logo_width }}"
          alt="{{ shop.name | escape }}"
          class="nav-logo-image"
          style="width: {{ settings.logo_width }}px;"
        >
      {% else %}
        <img src="{{ 'aren-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="nav-logo-image">
      {% endif %}
    </a>

    <div class="nav-links">
      <a href="{{ routes.root_url }}" class="nav-link{% if request.page_type == 'index' %} active{% endif %}">{{ settings.header_home_label | default: 'Home' }}</a>
      <a href="{{ about_url }}" class="nav-link{% if handle == 'about' %} active{% endif %}">{{ settings.header_about_label | default: 'About AREN' }}</a>
      <a href="{{ training_url }}" class="nav-link{% if handle == 'training' %} active{% endif %}">{{ settings.header_training_label | default: 'Training' }}</a>
      <a href="{{ services_url }}" class="nav-link{% if handle == 'services' %} active{% endif %}">{{ settings.header_services_label | default: 'Services' }}</a>
      <a href="{{ street_miles_url }}" class="nav-link{% if handle == 'street-miles' %} active{% endif %}">{{ settings.header_street_label | default: 'Street Miles NYC' }}</a>
      <a href="{{ shop_url }}" class="nav-link{% if handle == 'shop' or request.page_type == 'collection' or request.page_type == 'product' %} active{% endif %}">{{ settings.header_shop_label | default: 'Shop' }}</a>
      <a href="{{ contact_url }}" class="nav-link{% if handle == 'contact' %} active{% endif %}">{{ settings.header_contact_label | default: 'Contact / Join' }}</a>
    </div>

    <div class="nav-actions">
      <a href="{{ routes.account_login_url }}" class="nav-action-link">{{ settings.header_login_label | default: 'Log In' }}</a>
      <a href="{{ shop_url }}" class="nav-cta">{{ settings.header_cta_label | default: 'Shop Now' }}</a>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" type="button">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="nav-mobile" id="nav-mobile">
  <div class="nav-mobile-links">
    <a href="{{ routes.root_url }}" class="nav-mobile-link">{{ settings.header_home_label | default: 'Home' }}</a>
    <a href="{{ about_url }}" class="nav-mobile-link">{{ settings.header_about_label | default: 'About AREN' }}</a>
    <a href="{{ training_url }}" class="nav-mobile-link">{{ settings.header_training_label | default: 'Training' }}</a>
    <a href="{{ services_url }}" class="nav-mobile-link">{{ settings.header_services_label | default: 'Services' }}</a>
    <a href="{{ street_miles_url }}" class="nav-mobile-link">{{ settings.header_street_label | default: 'Street Miles NYC' }}</a>
    <a href="{{ shop_url }}" class="nav-mobile-link">{{ settings.header_shop_label | default: 'Shop' }}</a>
    <a href="{{ contact_url }}" class="nav-mobile-link">{{ settings.header_contact_label | default: 'Contact / Join' }}</a>
    <a href="{{ routes.account_login_url }}" class="nav-mobile-link">{{ settings.header_login_label | default: 'Log In' }}</a>
  </div>
</div>
