{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign shop_url = routes.all_products_collection_url | default: '/collections/all'
%}

<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }} home">
      {% if settings.logo != blank %}
        <img
          src="{{ settings.logo | image_url: width: settings.logo_width }}"
          alt="{{ shop.name | escape }}"
          class="nav-logo-image"
          style="width: {{ settings.logo_width }}px;"
        >
      {% else %}
        <img src="{{ 'aren-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="nav-logo-image">
      {% endif %}
    </a>

    <div class="nav-links">
      <a href="{{ routes.root_url }}" class="nav-link{% if request.page_type == 'index' %} active{% endif %}">Home</a>
      <a href="{{ about_url }}" class="nav-link{% if handle == 'about' %} active{% endif %}">About AREN</a>
      <a href="{{ training_url }}" class="nav-link{% if handle == 'training' %} active{% endif %}">Training</a>
      <a href="{{ services_url }}" class="nav-link{% if handle == 'services' %} active{% endif %}">Services</a>
      <a href="{{ street_miles_url }}" class="nav-link{% if handle == 'street-miles' %} active{% endif %}">Street Miles NYC</a>
      <a href="{{ shop_url }}" class="nav-link{% if request.page_type == 'collection' or request.page_type == 'product' %} active{% endif %}">Shop</a>
      <a href="{{ contact_url }}" class="nav-link{% if handle == 'contact' %} active{% endif %}">Contact / Join</a>
    </div>

    <div class="nav-actions">
      <a href="{{ routes.account_login_url }}" class="nav-action-link">Log In</a>
      <a href="{{ shop_url }}" class="nav-cta">Shop Now</a>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" type="button">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="nav-mobile" id="nav-mobile">
  <div class="nav-mobile-links">
    <a href="{{ routes.root_url }}" class="nav-mobile-link">Home</a>
    <a href="{{ about_url }}" class="nav-mobile-link">About AREN</a>
    <a href="{{ training_url }}" class="nav-mobile-link">Training</a>
    <a href="{{ services_url }}" class="nav-mobile-link">Services</a>
    <a href="{{ street_miles_url }}" class="nav-mobile-link">Street Miles NYC</a>
    <a href="{{ shop_url }}" class="nav-mobile-link">Shop</a>
    <a href="{{ contact_url }}" class="nav-mobile-link">Contact / Join</a>
    <a href="{{ routes.account_login_url }}" class="nav-mobile-link">Log In</a>
  </div>
</div>
