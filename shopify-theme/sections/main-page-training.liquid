{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign about_hero_image = section.settings.about_hero_image
  assign about_intro_image = section.settings.about_intro_image
  assign about_identity_image = section.settings.about_identity_image
  assign training_hero_image = section.settings.training_hero_image
  assign training_feature_image = section.settings.training_feature_image
  assign services_hero_image = section.settings.services_hero_image
  assign street_miles_hero_image = section.settings.street_miles_hero_image
  assign street_miles_culture_image = section.settings.street_miles_culture_image
  assign contact_hero_image = section.settings.contact_hero_image
  assign services_cta_image = section.settings.services_cta_image
  assign street_miles_quotes_image = section.settings.street_miles_quotes_image

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
  if section.settings.training_page != blank
    assign training_url = section.settings.training_page.url
  endif
  if section.settings.services_page != blank
    assign services_url = section.settings.services_page.url
  endif
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
  if section.settings.privacy_page != blank
    assign privacy_url = section.settings.privacy_page.url
  endif
  if section.settings.terms_page != blank
    assign terms_url = section.settings.terms_page.url
  endif
  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif
%}

  <div class="page-editor-surface page-editor-surface--training" data-page-handle="training" {{ section.shopify_attributes }}>
  <section class="page-hero page-hero--dark" style="position:relative;overflow:hidden;min-height:520px;display:flex;align-items:flex-end;">
    <div style="position:absolute;inset:0;{% if training_hero_image != blank %}background-image:url('{{ training_hero_image | image_url: width: 2000 }}');{% else %}background-image:url('https://static.wixstatic.com/media/8a3301_7e4d26bfdcf043e9a3212206d4f53db5~mv2.png/v1/crop/x_0,y_558,w_4284,h_4295/fill/w_1920,h_1080,al_c,q_90,enc_auto/8a3301_7e4d26bfdcf043e9a3212206d4f53db5~mv2.png');{% endif %}background-size:cover;background-position:center;"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(28,28,26,0.85) 0%,rgba(35,35,33,0.65) 60%,rgba(26,26,24,0.9) 100%);"></div>
    <div class="container" style="position:relative;z-index:1;padding-bottom:var(--space-xl);">
      <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="training_hero_eyebrow">{{ section.settings.training_hero_eyebrow }}</span></div>
      <h1 class="text-display" style="color:#fff;max-width:20ch;margin-bottom:2rem;"><span data-shopify-editor-setting="training_hero_heading">{{ section.settings.training_hero_heading }}</span></h1>
      <p style="font-size:1.0625rem;line-height:1.7;color:rgba(255,255,255,0.5);max-width:50ch;"><span data-shopify-editor-setting="training_hero_copy">{{ section.settings.training_hero_copy }}</span></p>
    </div>
  </section>

  <div class="marquee-strip"><div class="marquee-track"><span class="marquee-text"><span data-shopify-editor-setting="training_marquee_text">{{ section.settings.training_marquee_text }}</span></span><span class="marquee-text">{{ section.settings.training_marquee_text }}</span></div></div>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="training_philosophy_eyebrow">{{ section.settings.training_philosophy_eyebrow }}</span></div>
          <h2 class="text-h2"><span data-shopify-editor-setting="training_philosophy_heading">{{ section.settings.training_philosophy_heading }}</span></h2>
        </div>
        <div style="max-width:48ch;">
          <p class="text-body" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="training_philosophy_copy_1">{{ section.settings.training_philosophy_copy_1 }}</span></p>
          <p class="text-body"><span data-shopify-editor-setting="training_philosophy_copy_2">{{ section.settings.training_philosophy_copy_2 }}</span></p>
        </div>
      </div>

      <div style="display:flex;gap:3rem;margin-top:2.5rem;padding-top:2.5rem;border-top:1px solid var(--color-warm-gray);flex-wrap:wrap;">
        {% for block in section.blocks %}
          {% if block.type == 'training_principle' %}
            <div {{ block.shopify_attributes }}>
              <div style="font-family:var(--font-mono);font-size:0.5rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-mid-gray);margin-bottom:0.5rem;">{{ block.settings.number }}</div>
              <div style="font-family:var(--font-sans);font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div style="position:relative;overflow:hidden;aspect-ratio:3/4;min-height:400px;">
      {% if training_feature_image != blank %}
        <img src="{{ training_feature_image | image_url: width: 1200 }}" alt="{{ training_feature_image.alt | default: 'AREN Training' | escape }}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy" />
      {% else %}
        <img src="https://static.wixstatic.com/media/8a3301_b34c7842f2ee4961a0607531ffdcc869~mv2.png/v1/crop/x_0,y_1000,w_3024,h_3032/fill/w_800,h_1000,al_c,q_90,enc_auto/8a3301_b34c7842f2ee4961a0607531ffdcc869~mv2.png" alt="AREN Training" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy" />
      {% endif %}
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(35,35,33,0.4) 0%,transparent 50%);"></div>
    </div>
  </section>

  <section class="section" style="border-top:1px solid var(--color-warm-gray);border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="training_programs_eyebrow">{{ section.settings.training_programs_eyebrow }}</span></div>
          <h2 class="text-h2"><span data-shopify-editor-setting="training_programs_heading">{{ section.settings.training_programs_heading }}</span></h2>
        </div>
      </div>

      <div class="services-list" style="border-top:none;">
        {% for block in section.blocks %}
          {% if block.type == 'training_program' %}
            {% liquid
              assign training_program_url = contact_url
              if block.settings.link_type == 'street_miles'
                assign training_program_url = street_miles_url
              elsif block.settings.link_type == 'training'
                assign training_program_url = training_url
              elsif block.settings.link_type == 'shop'
                assign training_program_url = shop_url
              elsif block.settings.link != blank
                assign training_program_url = block.settings.link
              endif
            %}
            <div class="service-row" {{ block.shopify_attributes }}>
              <div>
                <div class="text-eyebrow" style="margin-bottom:.75rem;">{{ block.settings.eyebrow }}</div>
                <div class="service-name">{{ block.settings.title }}</div>
              </div>
              <div class="service-desc">{{ block.settings.description }}</div>
              <div class="service-arrow"><a href="{{ training_program_url }}">{{ block.settings.link_label }}</a></div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1.2fr) minmax(0,.8fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="training_who_eyebrow">{{ section.settings.training_who_eyebrow }}</span></div>
        <h2 class="text-h2" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="training_who_heading">{{ section.settings.training_who_heading }}</span></h2>
        <ul class="text-body" style="list-style:none;padding:0;margin:0;display:grid;gap:1rem;">
          {% for block in section.blocks %}
            {% if block.type == 'training_who_item' %}
              <li {{ block.shopify_attributes }}>— {{ block.settings.text }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
      <div class="training-grid" style="grid-template-columns:1fr;gap:1rem;">
        {% for block in section.blocks %}
          {% if block.type == 'training_metric' %}
            <div class="training-card" {{ block.shopify_attributes }}><div class="training-card-number">{{ block.settings.value }}</div><div class="training-card-title">{{ block.settings.label }}</div></div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);border-top:1px solid var(--color-warm-gray);">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="training_get_started_eyebrow">{{ section.settings.training_get_started_eyebrow }}</span></div>
        <h2 class="text-h2" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="training_get_started_heading">{{ section.settings.training_get_started_heading }}</span></h2>
        <p class="text-body" style="margin-bottom:1rem;"><span data-shopify-editor-setting="training_get_started_copy">{{ section.settings.training_get_started_copy }}</span></p>
        <p class="text-body" style="margin-bottom:.5rem;"><a href="mailto:{{ settings.email_address | default: 'info@arenathletic.com' }}">{{ settings.email_address | default: 'info@arenathletic.com' }}</a></p>
        <p class="text-body"><span data-shopify-editor-setting="training_get_started_address">{{ section.settings.training_get_started_address }}</span></p>
      </div>
      <div>
        {% form 'contact', id: 'training-contact-form', class: 'contact-form' %}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
              <label class="form-label" for="TrainingFirstName"><span data-shopify-editor-setting="training_form_first_name_label">{{ section.settings.training_form_first_name_label }}</span></label>
              <input class="form-input" type="text" id="TrainingFirstName" name="contact[first_name]" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="TrainingLastName"><span data-shopify-editor-setting="training_form_last_name_label">{{ section.settings.training_form_last_name_label }}</span></label>
              <input class="form-input" type="text" id="TrainingLastName" name="contact[last_name]" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="TrainingEmail"><span data-shopify-editor-setting="training_form_email_label">{{ section.settings.training_form_email_label }}</span></label>
            <input class="form-input" type="email" id="TrainingEmail" name="contact[email]" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="TrainingPhone"><span data-shopify-editor-setting="training_form_phone_label">{{ section.settings.training_form_phone_label }}</span></label>
            <input class="form-input" type="tel" id="TrainingPhone" name="contact[phone]">
          </div>
          <div class="form-group">
            <label class="form-label" for="TrainingReferral"><span data-shopify-editor-setting="training_form_referral_label">{{ section.settings.training_form_referral_label }}</span></label>
            <input class="form-input" type="text" id="TrainingReferral" name="contact[referral_source]">
          </div>
          <div class="form-group">
            <label class="form-label" for="TrainingWhy"><span data-shopify-editor-setting="training_form_body_label">{{ section.settings.training_form_body_label }}</span></label>
            <textarea class="form-textarea" id="TrainingWhy" name="contact[body]" required></textarea>
          </div>
          <button class="btn btn--primary" type="submit"><span data-shopify-editor-setting="training_form_button_label">{{ section.settings.training_form_button_label }}</span></button>
          <div class="text-eyebrow" style="margin-top:1rem;"><span data-shopify-editor-setting="training_form_response_text">{{ section.settings.training_form_response_text }}</span></div>
          {% if form.posted_successfully? %}
            <div id="training-contact-success" class="text-eyebrow" style="display:block;margin-top:1rem;"><span data-shopify-editor-setting="training_form_success_text">{{ section.settings.training_form_success_text }}</span></div>
          {% endif %}
          {{ form.errors | default_errors }}
        {% endform %}
      </div>
    </div>
  </section>

  {% if page.content != blank %}<section class="section"><div class="container rte">{{ page.content }}</div></section>{% endif %}

{% schema %}
{
  "name": "Training page",
  "settings": [
    { "type": "header", "content": "Training page editor settings" },
    { "type": "page", "id": "about_page", "label": "About page" },
    { "type": "page", "id": "training_page", "label": "Training page" },
    { "type": "page", "id": "services_page", "label": "Services page" },
    { "type": "page", "id": "street_miles_page", "label": "Street Miles page" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "page", "id": "privacy_page", "label": "Privacy page" },
    { "type": "page", "id": "terms_page", "label": "Terms page" },
    { "type": "page", "id": "shop_page", "label": "Shop page" },
    { "type": "text", "id": "training_hero_eyebrow", "label": "Training hero eyebrow", "default": "Aren Athletic &bull; Discipline" },
    { "type": "image_picker", "id": "training_hero_image", "label": "Training hero image" },
    { "type": "html", "id": "training_hero_heading", "label": "Training hero heading", "default": "Built by Discipline.<br>Proven by Action." },
    { "type": "textarea", "id": "training_hero_copy", "label": "Training hero copy", "default": "Uncompromising execution and elite standards. Our systems are built for the high-level athlete where performance must be validated by measurable output and structured accountability." },
    { "type": "textarea", "id": "training_marquee_text", "label": "Training marquee text", "default": "AREN ATHLETIC — NEW YORK CITY — DISCIPLINE AND PERFORMANCE — STREET MILES NYC — FIVE BOROUGH CHAPTER — STRUCTURED PERFORMANCE — AREN ATHLETIC COLLECTIVE — APPAREL BUILT FOR TRAINING —" },
    { "type": "text", "id": "training_philosophy_eyebrow", "label": "Training philosophy eyebrow", "default": "Philosophy" },
    { "type": "html", "id": "training_philosophy_heading", "label": "Training philosophy heading", "default": "Built by Discipline.<br>Proven by Action." },
    { "type": "textarea", "id": "training_philosophy_copy_1", "label": "Training philosophy copy 1", "default": "The AREN performance system is built on structured discipline and uncompromising accountability. Every protocol is designed for the serious athlete who values output over opinion." },
    { "type": "textarea", "id": "training_philosophy_copy_2", "label": "Training philosophy copy 2", "default": "We operate on a hierarchy of performance where intent must be validated by action. We define the standard; you execute the work." },
    { "type": "image_picker", "id": "training_feature_image", "label": "Training feature image" },
    { "type": "text", "id": "training_programs_eyebrow", "label": "Training programs eyebrow", "default": "Performance Systems" },
    { "type": "text", "id": "training_programs_heading", "label": "Training programs heading", "default": "Programs built for athletes who train with intent." },
    { "type": "text", "id": "training_who_eyebrow", "label": "Training who eyebrow", "default": "Who Trains With Intent?" },
    { "type": "text", "id": "training_who_heading", "label": "Training who heading", "default": "The standard is not for everyone." },
    { "type": "text", "id": "training_get_started_eyebrow", "label": "Training get started eyebrow", "default": "Get Started" },
    { "type": "text", "id": "training_get_started_heading", "label": "Training get started heading", "default": "Execute the first step." },
    { "type": "textarea", "id": "training_get_started_copy", "label": "Training get started copy", "default": "Response Protocol: 24h. We respond to all serious inquiries within 24 hours." },
    { "type": "text", "id": "training_get_started_address", "label": "Training address", "default": "37 Union Sq West, 2nd Floor, New York, NY 10003" },
    { "type": "text", "id": "training_form_first_name_label", "label": "Training form first name label", "default": "First Name *" },
    { "type": "text", "id": "training_form_last_name_label", "label": "Training form last name label", "default": "Last Name *" },
    { "type": "text", "id": "training_form_email_label", "label": "Training form email label", "default": "Email *" },
    { "type": "text", "id": "training_form_phone_label", "label": "Training form phone label", "default": "Phone" },
    { "type": "text", "id": "training_form_referral_label", "label": "Training form referral label", "default": "Referral Source" },
    { "type": "text", "id": "training_form_body_label", "label": "Training form body label", "default": "Why are you looking to train? *" },
    { "type": "text", "id": "training_form_button_label", "label": "Training form button label", "default": "Submit" },
    { "type": "text", "id": "training_form_response_text", "label": "Training form response text", "default": "Response Protocol: 24h" },
    { "type": "textarea", "id": "training_form_success_text", "label": "Training form success text", "default": "Received.<br>We'll be in touch within 24 hours." }
  ],
  "blocks": [
    {
      "type": "training_principle",
      "name": "Training principle",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "label", "label": "Label", "default": "Presence." }
      ]
    },
    {
      "type": "training_program",
      "name": "Training program",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "01 / PROTOCOL" },
        { "type": "text", "id": "title", "label": "Title", "default": "Protocol — Threshold" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Advanced performance development emphasizing neural efficiency, force production, and high-intensity execution. Built for athletes operating above baseline standards and seeking elevated output within a controlled training environment." },
        { "type": "select", "id": "link_type", "label": "Link type", "default": "contact", "options": [
          { "value": "contact", "label": "Contact page" },
          { "value": "training", "label": "Training page" },
          { "value": "street_miles", "label": "Street Miles page" },
          { "value": "shop", "label": "Shop page" },
          { "value": "custom", "label": "Custom URL" }
        ] },
        { "type": "url", "id": "link", "label": "Custom link" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Apply for Threshold" }
      ]
    },
    {
      "type": "training_who_item",
      "name": "Training audience item",
      "limit": 6,
      "settings": [
        { "type": "textarea", "id": "text", "label": "Text", "default": "Individuals who prioritize performance output over public opinion." }
      ]
    },
    {
      "type": "training_metric",
      "name": "Training metric",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "100%" },
        { "type": "text", "id": "label", "label": "Label", "default": "Execution" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Training page"
    }
  ]
}
{% endschema %}
