{% liquid
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
%}

<section class="section">
  <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.95fr);gap:var(--space-xl);align-items:center;">
    <div style="position:relative;overflow:hidden;aspect-ratio:4/5;background-size:cover;background-position:center;{% if section.settings.image != blank %}background-image:url('{{ section.settings.image | image_url: width: 1600 }}');{% elsif settings.default_street_miles_image != blank %}background-image:url('{{ settings.default_street_miles_image | image_url: width: 1600 }}');{% elsif section.settings.fallback_image_url != blank %}background-image:url('{{ section.settings.fallback_image_url }}');{% endif %}">
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(35,35,33,0.45) 0%,transparent 50%);"></div>
      <div style="position:absolute;left:1.5rem;bottom:1.5rem;right:1.5rem;color:#fff;z-index:1;">
        {% if section.settings.image_eyebrow != blank %}<div class="text-eyebrow" style="color:rgba(255,255,255,0.35);margin-bottom:1rem;">{{ section.settings.image_eyebrow }}</div>{% endif %}
        {% if section.settings.image_heading != blank %}<div class="text-h2" style="color:#fff;">{{ section.settings.image_heading }}</div>{% endif %}
      </div>
    </div>
    <div>
      {% if section.settings.eyebrow != blank %}<div class="text-eyebrow mb-sm">{{ section.settings.eyebrow }}</div>{% endif %}
      {% if section.settings.heading != blank %}<h2 class="text-h2" style="margin-bottom:1.25rem;">{{ section.settings.heading }}</h2>{% endif %}
      {% if section.settings.copy != blank %}<div class="text-body rte" style="margin-bottom:2rem;max-width:42ch;">{{ section.settings.copy }}</div>{% endif %}
      <div class="training-grid" style="grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;margin-bottom:2rem;">
        {% for block in section.blocks %}
          <div class="training-card" {{ block.shopify_attributes }}>
            <div class="training-card-number">{{ block.settings.value }}</div>
            <div class="training-card-title">{{ block.settings.label }}</div>
          </div>
        {% endfor %}
      </div>
      {% if section.settings.button_label != blank %}<a href="{{ street_miles_url }}" class="btn btn--outline">{{ section.settings.button_label }}</a>{% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Street Miles",
  "settings": [
    { "type": "page", "id": "street_miles_page", "label": "Street Miles page" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Street Miles" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Street Miles NYC" },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>A weekly run club built on exploration, effort, and community — moving through the city together.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore Street Miles" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image_url", "label": "Fallback image URL" },
    { "type": "text", "id": "image_eyebrow", "label": "Image eyebrow", "default": "SMNYC / FIVE BOROUGH CHAPTER" },
    { "type": "html", "id": "image_heading", "label": "Image heading", "default": "Do the work.<br>Carry the weight." }
  ],
  "blocks": [
    {
      "type": "street_stat",
      "name": "Street Miles stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "5" },
        { "type": "text", "id": "label", "label": "Label", "default": "Boroughs" }
      ]
    }
  ],
  "presets": [{ "name": "Home Street Miles", "blocks": [{ "type": "street_stat" }, { "type": "street_stat" }, { "type": "street_stat" }] }]
}
{% endschema %}
