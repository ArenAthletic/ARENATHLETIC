{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign about_hero_image = section.settings.about_hero_image
  assign about_intro_image = section.settings.about_intro_image
  assign about_identity_image = section.settings.about_identity_image
  assign training_hero_image = section.settings.training_hero_image
  assign training_feature_image = section.settings.training_feature_image
  assign services_hero_image = section.settings.services_hero_image
  assign street_miles_hero_image = section.settings.street_miles_hero_image
  assign street_miles_culture_image = section.settings.street_miles_culture_image
  assign contact_hero_image = section.settings.contact_hero_image
  assign services_cta_image = section.settings.services_cta_image
  assign street_miles_quotes_image = section.settings.street_miles_quotes_image

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
  if section.settings.training_page != blank
    assign training_url = section.settings.training_page.url
  endif
  if section.settings.services_page != blank
    assign services_url = section.settings.services_page.url
  endif
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
  if section.settings.privacy_page != blank
    assign privacy_url = section.settings.privacy_page.url
  endif
  if section.settings.terms_page != blank
    assign terms_url = section.settings.terms_page.url
  endif
  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif
%}

  <div class="page-editor-surface page-editor-surface--street-miles" data-page-handle="street-miles" {{ section.shopify_attributes }}>
  <section class="sm-hero" style="position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;{% if street_miles_hero_image != blank %}background-image:url('{{ street_miles_hero_image | image_url: width: 2000 }}');{% else %}background-image:url('https://static.wixstatic.com/media/8a3301_dfd7f8236654470390a4357692431d22~mv2.png/v1/fill/w_1920,h_1080,al_c,q_90,enc_auto/8a3301_dfd7f8236654470390a4357692431d22~mv2.png');{% endif %}background-size:cover;background-position:center top;"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(20,20,18,0.88) 0%,rgba(35,35,33,0.70) 55%,rgba(20,20,18,0.92) 100%);"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:2.5rem;"><span data-shopify-editor-setting="street_miles_hero_eyebrow">{{ section.settings.street_miles_hero_eyebrow }}</span></div>
      <h1 class="sm-hero-tagline"><span data-shopify-editor-setting="street_miles_hero_heading">{{ section.settings.street_miles_hero_heading }}</span></h1>
      <p style="font-size:1.0625rem;line-height:1.7;color:rgba(255,255,255,0.5);max-width:52ch;margin-bottom:3rem;"><span data-shopify-editor-setting="street_miles_hero_copy">{{ section.settings.street_miles_hero_copy }}</span></p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="{{ contact_url }}" class="btn btn--primary"><span data-shopify-editor-setting="street_miles_primary_label">{{ section.settings.street_miles_primary_label }}</span></a>
        <a href="#protocol" class="btn btn--outline-white"><span data-shopify-editor-setting="street_miles_secondary_label">{{ section.settings.street_miles_secondary_label }}</span></a>
      </div>
    </div>
  </section>

  <div class="marquee-strip"><div class="marquee-track"><span class="marquee-text"><span data-shopify-editor-setting="street_miles_marquee_text">{{ section.settings.street_miles_marquee_text }}</span></span><span class="marquee-text">{{ section.settings.street_miles_marquee_text }}</span></div></div>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:center;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="street_miles_culture_eyebrow">{{ section.settings.street_miles_culture_eyebrow }}</span></div>
        <h2 class="text-h2" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="street_miles_culture_heading">{{ section.settings.street_miles_culture_heading }}</span></h2>
        <p class="text-body" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="street_miles_culture_copy_1">{{ section.settings.street_miles_culture_copy_1 }}</span></p>
        <p class="text-body" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="street_miles_culture_copy_2">{{ section.settings.street_miles_culture_copy_2 }}</span></p>
        <p class="text-body"><span data-shopify-editor-setting="street_miles_culture_copy_3">{{ section.settings.street_miles_culture_copy_3 }}</span></p>
      </div>
      <div style="position:relative;overflow:hidden;aspect-ratio:4/5;">
        {% if street_miles_culture_image != blank %}
          <img src="{{ street_miles_culture_image | image_url: width: 1200 }}" alt="{{ street_miles_culture_image.alt | default: 'Street Miles NYC' | escape }}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
        {% else %}
          <img src="https://static.wixstatic.com/media/8a3301_8a94a47601dd469abbfc6e2cf79dd39a~mv2.png/v1/fill/w_900,h_1125,al_c,q_90,enc_auto/8a3301_8a94a47601dd469abbfc6e2cf79dd39a~mv2.png" alt="Street Miles NYC" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
        {% endif %}
      </div>
    </div>
  </section>

  <section class="section" id="protocol" style="border-top:1px solid var(--color-warm-gray);border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="street_miles_protocol_eyebrow">{{ section.settings.street_miles_protocol_eyebrow }}</span></div>
      <h2 class="text-h2" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="street_miles_protocol_heading">{{ section.settings.street_miles_protocol_heading }}</span></h2>
      <div class="services-list" style="border-top:none;">
        {% for block in section.blocks %}
          {% if block.type == 'street_protocol' %}
            <div class="service-row" {{ block.shopify_attributes }}>
              <div>
                <div class="text-eyebrow" style="margin-bottom:.75rem;">{{ block.settings.eyebrow }}</div>
                <div class="service-name">{{ block.settings.title }}</div>
              </div>
              <div class="service-desc">{{ block.settings.description }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="street_miles_chapter_eyebrow">{{ section.settings.street_miles_chapter_eyebrow }}</span></div>
        <h2 class="text-h2" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="street_miles_chapter_heading">{{ section.settings.street_miles_chapter_heading }}</span></h2>
        <p class="text-body" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="street_miles_chapter_copy_1">{{ section.settings.street_miles_chapter_copy_1 }}</span></p>
        <p class="text-body"><span data-shopify-editor-setting="street_miles_chapter_copy_2">{{ section.settings.street_miles_chapter_copy_2 }}</span></p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;">
        {% for block in section.blocks %}
          {% if block.type == 'street_stat_card' %}
            <div style="padding:2.5rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);" {{ block.shopify_attributes }}>
              <div style="font-family:var(--font-display);font-size:clamp(2.5rem,4vw,3.5rem);font-weight:700;color:#fff;margin-bottom:0.5rem;line-height:0.95;text-transform:uppercase;letter-spacing:-0.01em;">{{ block.settings.value }}</div>
              <div class="text-eyebrow" style="color:rgba(255,255,255,0.3);">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);border-top:1px solid var(--color-warm-gray);border-bottom:1px solid var(--color-warm-gray);position:relative;overflow:hidden;">
    {% if street_miles_quotes_image != blank %}
      <div style="position:absolute;inset:0;background-image:url('{{ street_miles_quotes_image | image_url: width: 2000 }}');background-size:cover;background-position:center;opacity:0.08;"></div>
    {% endif %}
    <div class="container" style="position:relative;z-index:1;">
      <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="street_miles_quotes_eyebrow">{{ section.settings.street_miles_quotes_eyebrow }}</span></div>
      <div class="training-grid" style="grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;">
        {% for block in section.blocks %}
          {% if block.type == 'street_quote' %}
            <div class="training-card" {{ block.shopify_attributes }}><div class="training-card-desc">{{ block.settings.quote }}</div><div class="text-eyebrow" style="margin-top:1rem;">{{ block.settings.attribution }}</div></div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.8fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="street_miles_access_eyebrow">{{ section.settings.street_miles_access_eyebrow }}</span></div>
        <div class="training-grid" style="grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;">
          {% for block in section.blocks %}
            {% if block.type == 'street_access_step' %}
              <div class="training-card" {{ block.shopify_attributes }}><div class="training-card-number">{{ block.settings.number }}</div><div class="training-card-title">{{ block.settings.title }}</div><div class="training-card-desc">{{ block.settings.description }}</div></div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div style="display:grid;align-content:start;">
        <a href="{{ contact_url }}" class="btn btn--primary"><span data-shopify-editor-setting="street_miles_access_button_label">{{ section.settings.street_miles_access_button_label }}</span></a>
      </div>
    </div>
  </section>

  {% if page.content != blank %}<section class="section"><div class="container rte">{{ page.content }}</div></section>{% endif %}
  </div>

