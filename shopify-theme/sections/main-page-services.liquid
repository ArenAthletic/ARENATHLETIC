{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign about_hero_image = section.settings.about_hero_image
  assign about_intro_image = section.settings.about_intro_image
  assign about_identity_image = section.settings.about_identity_image
  assign training_hero_image = section.settings.training_hero_image
  assign training_feature_image = section.settings.training_feature_image
  assign services_hero_image = section.settings.services_hero_image
  assign street_miles_hero_image = section.settings.street_miles_hero_image
  assign street_miles_culture_image = section.settings.street_miles_culture_image
  assign contact_hero_image = section.settings.contact_hero_image
  assign services_cta_image = section.settings.services_cta_image
  assign street_miles_quotes_image = section.settings.street_miles_quotes_image

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
  if section.settings.training_page != blank
    assign training_url = section.settings.training_page.url
  endif
  if section.settings.services_page != blank
    assign services_url = section.settings.services_page.url
  endif
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
  if section.settings.privacy_page != blank
    assign privacy_url = section.settings.privacy_page.url
  endif
  if section.settings.terms_page != blank
    assign terms_url = section.settings.terms_page.url
  endif
  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif
%}

  <div class="page-editor-surface page-editor-surface--services" data-page-handle="services" {{ section.shopify_attributes }}>
  <section class="page-hero" style="position:relative;overflow:hidden;padding-top:calc(68px + var(--space-xl));padding-bottom:var(--space-xl);border-bottom:1px solid var(--color-warm-gray);">
    <div style="position:absolute;inset:0;{% if services_hero_image != blank %}background-image:url('{{ services_hero_image | image_url: width: 2000 }}');{% else %}background-image:url('https://static.wixstatic.com/media/8a3301_cf5517a609d94d6992c825205aaae6d6~mv2.png/v1/fill/w_1920,h_600,al_c,q_90,enc_auto/8a3301_cf5517a609d94d6992c825205aaae6d6~mv2.png');{% endif %}background-size:cover;background-position:center;opacity:0.08;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="services_hero_eyebrow">{{ section.settings.services_hero_eyebrow }}</span></div>
      <h1 class="text-h1" style="max-width:20ch;margin-bottom:2rem;"><span data-shopify-editor-setting="services_hero_heading">{{ section.settings.services_hero_heading }}</span></h1>
      <p class="text-body" style="max-width:50ch;"><span data-shopify-editor-setting="services_hero_copy">{{ section.settings.services_hero_copy }}</span></p>
    </div>
  </section>

  <div class="marquee-strip"><div class="marquee-track"><span class="marquee-text"><span data-shopify-editor-setting="services_marquee_text">{{ section.settings.services_marquee_text }}</span></span><span class="marquee-text">{{ section.settings.services_marquee_text }}</span></div></div>

  <section class="services-list">
    <div class="container">
      {% for block in section.blocks %}
        {% if block.type == 'services_item' %}
          {% liquid
            assign services_item_url = contact_url
            if block.settings.link_type == 'street_miles'
              assign services_item_url = street_miles_url
            elsif block.settings.link_type == 'training'
              assign services_item_url = training_url
            elsif block.settings.link_type == 'shop'
              assign services_item_url = shop_url
            elsif block.settings.link != blank
              assign services_item_url = block.settings.link
            endif
          %}
          <div class="service-row" {{ block.shopify_attributes }}>
            <div>
              <div class="text-eyebrow" style="margin-bottom:0.75rem;">{{ block.settings.number }}</div>
              <div class="service-name">{{ block.settings.title }}</div>
            </div>
            <div class="service-desc">{{ block.settings.description }}</div>
            <div class="service-arrow"><a href="{{ services_item_url }}">{{ block.settings.link_label }}</a></div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);border-top:1px solid var(--color-warm-gray);">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="services_cta_eyebrow">{{ section.settings.services_cta_eyebrow }}</span></div>
        <h2 class="text-h2" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="services_cta_heading">{{ section.settings.services_cta_heading }}</span></h2>
        <p class="text-body" style="margin-bottom:1.5rem;"><span data-shopify-editor-setting="services_cta_copy">{{ section.settings.services_cta_copy }}</span></p>
      </div>
      <div style="display:grid;gap:1rem;align-content:start;">
        {% if services_cta_image != blank %}
          <div style="position:relative;overflow:hidden;aspect-ratio:4/5;margin-bottom:1rem;">
            <img src="{{ services_cta_image | image_url: width: 1200 }}" alt="{{ services_cta_image.alt | default: section.settings.services_cta_heading | escape }}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">
          </div>
        {% endif %}
        <a href="{{ contact_url }}" class="btn btn--primary"><span data-shopify-editor-setting="services_cta_primary_label">{{ section.settings.services_cta_primary_label }}</span></a>
        <a href="{{ training_url }}" class="btn btn--outline"><span data-shopify-editor-setting="services_cta_secondary_label">{{ section.settings.services_cta_secondary_label }}</span></a>
        <a href="{{ street_miles_url }}" class="btn btn--outline"><span data-shopify-editor-setting="services_cta_tertiary_label">{{ section.settings.services_cta_tertiary_label }}</span></a>
      </div>
    </div>
  </section>

  {% if page.content != blank %}<section class="section"><div class="container rte">{{ page.content }}</div></section>{% endif %}
  </div>

{% schema %}
{
  "name": "Services page",
  "settings": [
    { "type": "header", "content": "Services page editor settings" },
    { "type": "page", "id": "about_page", "label": "About page" },
    { "type": "page", "id": "training_page", "label": "Training page" },
    { "type": "page", "id": "services_page", "label": "Services page" },
    { "type": "page", "id": "street_miles_page", "label": "Street Miles page" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "page", "id": "privacy_page", "label": "Privacy page" },
    { "type": "page", "id": "terms_page", "label": "Terms page" },
    { "type": "page", "id": "shop_page", "label": "Shop page" },
    { "type": "text", "id": "services_hero_eyebrow", "label": "Services hero eyebrow", "default": "Services" },
    { "type": "image_picker", "id": "services_hero_image", "label": "Services hero image" },
    { "type": "html", "id": "services_hero_heading", "label": "Services hero heading", "default": "Structured access.<br>Every level." },
    { "type": "textarea", "id": "services_hero_copy", "label": "Services hero copy", "default": "AREN offers a tiered service ecosystem for athletes and communities. From individual programming to full chapter activation — the standard scales to your context." },
    { "type": "textarea", "id": "services_marquee_text", "label": "Services marquee text", "default": "AREN ATHLETIC — NEW YORK CITY — DISCIPLINE AND PERFORMANCE — STREET MILES NYC — FIVE BOROUGH CHAPTER — STRUCTURED PERFORMANCE — AREN ATHLETIC COLLECTIVE — APPAREL BUILT FOR TRAINING —" },
    { "type": "text", "id": "services_cta_eyebrow", "label": "Services CTA eyebrow", "default": "National Performance Platform" },
    { "type": "text", "id": "services_cta_heading", "label": "Services CTA heading", "default": "Building a scalable culture of community chapters across the nation." },
    { "type": "textarea", "id": "services_cta_copy", "label": "Services CTA copy", "default": "AREN is evolving into a coordinated performance ecosystem, establishing elite training protocols and community expression while maintaining the absolute integrity of the standard." },
    { "type": "image_picker", "id": "services_cta_image", "label": "Services CTA image" },
    { "type": "text", "id": "services_cta_primary_label", "label": "Services CTA primary label", "default": "Contact / Join the Community" },
    { "type": "text", "id": "services_cta_secondary_label", "label": "Services CTA secondary label", "default": "Explore Training Programs" },
    { "type": "text", "id": "services_cta_tertiary_label", "label": "Services CTA tertiary label", "default": "Join Street Miles NYC" }
  ],
  "blocks": [
    {
      "type": "services_item",
      "name": "Services item",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Individual Programming" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Custom training programs built around the individual athlete's goals, schedule, and environment. Periodized, progressive, and designed for long-term development. Remote coaching available nationally." },
        { "type": "select", "id": "link_type", "label": "Link type", "default": "contact", "options": [
          { "value": "contact", "label": "Contact page" },
          { "value": "training", "label": "Training page" },
          { "value": "street_miles", "label": "Street Miles page" },
          { "value": "shop", "label": "Shop page" },
          { "value": "custom", "label": "Custom URL" }
        ] },
        { "type": "url", "id": "link", "label": "Custom link" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Inquire" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services page"
    }
  ]
}
{% endschema %}
