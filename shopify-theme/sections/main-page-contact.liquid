{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign about_hero_image = section.settings.about_hero_image
  assign about_intro_image = section.settings.about_intro_image
  assign about_identity_image = section.settings.about_identity_image
  assign training_hero_image = section.settings.training_hero_image
  assign training_feature_image = section.settings.training_feature_image
  assign services_hero_image = section.settings.services_hero_image
  assign street_miles_hero_image = section.settings.street_miles_hero_image
  assign street_miles_culture_image = section.settings.street_miles_culture_image
  assign contact_hero_image = section.settings.contact_hero_image
  assign services_cta_image = section.settings.services_cta_image
  assign street_miles_quotes_image = section.settings.street_miles_quotes_image

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
  if section.settings.training_page != blank
    assign training_url = section.settings.training_page.url
  endif
  if section.settings.services_page != blank
    assign services_url = section.settings.services_page.url
  endif
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
  if section.settings.privacy_page != blank
    assign privacy_url = section.settings.privacy_page.url
  endif
  if section.settings.terms_page != blank
    assign terms_url = section.settings.terms_page.url
  endif
  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif
%}

  <div class="page-editor-surface page-editor-surface--contact" data-page-handle="contact" {{ section.shopify_attributes }}>
  <section style="position:relative;padding-top:calc(68px + var(--space-xl));padding-bottom:var(--space-xl);border-bottom:1px solid var(--color-warm-gray);overflow:hidden;">
    <div style="position:absolute;inset:0;{% if contact_hero_image != blank %}background-image:url('{{ contact_hero_image | image_url: width: 2000 }}');{% else %}background-image:url('https://static.wixstatic.com/media/8a3301_a50d3c308c3b4909b7726a0559353904~mv2.jpg/v1/crop/x_0,y_2549,w_3840,h_2057/fill/w_1920,h_600,al_c,q_90,enc_auto/8a3301_a50d3c308c3b4909b7726a0559353904~mv2.jpg');{% endif %}background-size:cover;background-position:center;opacity:0.08;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:end;">
        <div>
          <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="contact_hero_eyebrow">{{ section.settings.contact_hero_eyebrow }}</span></div>
          <h1 class="text-h1" style="max-width:18ch;"><span data-shopify-editor-setting="contact_hero_heading">{{ section.settings.contact_hero_heading }}</span></h1>
        </div>
        <p class="text-body" style="max-width:44ch;"><span data-shopify-editor-setting="contact_hero_copy">{{ section.settings.contact_hero_copy }}</span></p>
      </div>
    </div>
  </section>

  <div class="marquee-strip"><div class="marquee-track"><span class="marquee-text"><span data-shopify-editor-setting="contact_marquee_text">{{ section.settings.contact_marquee_text }}</span></span><span class="marquee-text">{{ section.settings.contact_marquee_text }}</span></div></div>

  <section class="section" style="border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="contact_channels_heading">{{ section.settings.contact_channels_heading }}</span></div>
      <div class="training-grid" style="grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;">
        {% for block in section.blocks %}
          {% if block.type == 'contact_channel' %}
            <div class="training-card" {{ block.shopify_attributes }}><div class="training-card-title">{{ block.settings.title }}</div><div class="training-card-desc">{{ block.settings.description }}</div></div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,.95fr) minmax(0,1.05fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="contact_social_heading">{{ section.settings.contact_social_heading }}</span></div>
        <div class="footer-links" style="gap:1rem;display:grid;">
          <a href="{{ settings.instagram_url | default: 'https://www.instagram.com/arenathletic/' }}" class="footer-link">Instagram</a>
          <a href="{{ settings.twitter_url | default: 'https://x.com/' }}" class="footer-link">Twitter</a>
          <a href="{{ settings.youtube_url | default: 'https://www.youtube.com/' }}" class="footer-link">YouTube</a>
        </div>
      </div>
      <div>
        {% form 'contact', id: 'contact-form', class: 'contact-form' %}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
              <label class="form-label" for="ContactFormFirstName"><span data-shopify-editor-setting="contact_form_first_name_label">{{ section.settings.contact_form_first_name_label }}</span></label>
              <input class="form-input" type="text" id="ContactFormFirstName" name="contact[first_name]">
            </div>
            <div class="form-group">
              <label class="form-label" for="ContactFormLastName"><span data-shopify-editor-setting="contact_form_last_name_label">{{ section.settings.contact_form_last_name_label }}</span></label>
              <input class="form-input" type="text" id="ContactFormLastName" name="contact[last_name]">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="ContactFormEmail"><span data-shopify-editor-setting="contact_form_email_label">{{ section.settings.contact_form_email_label }}</span></label>
            <input class="form-input" type="email" id="ContactFormEmail" name="contact[email]" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="ContactFormPhone"><span data-shopify-editor-setting="contact_form_phone_label">{{ section.settings.contact_form_phone_label }}</span></label>
            <input class="form-input" type="tel" id="ContactFormPhone" name="contact[phone]">
          </div>
          <div class="form-group">
            <label class="form-label" for="ContactFormReferral"><span data-shopify-editor-setting="contact_form_referral_label">{{ section.settings.contact_form_referral_label }}</span></label>
            <input class="form-input" type="text" id="ContactFormReferral" name="contact[referral_source]">
          </div>
          <div class="form-group">
            <label class="form-label" for="ContactFormBody"><span data-shopify-editor-setting="contact_form_body_label">{{ section.settings.contact_form_body_label }}</span></label>
            <textarea class="form-textarea" id="ContactFormBody" name="contact[body]"></textarea>
          </div>
          <button class="btn btn--primary" type="submit"><span data-shopify-editor-setting="contact_form_button_label">{{ section.settings.contact_form_button_label }}</span></button>
          {% if form.posted_successfully? %}
            <div id="contact-success" class="text-eyebrow" style="display:block;margin-top:1rem;"><span data-shopify-editor-setting="contact_form_success_text">{{ section.settings.contact_form_success_text }}</span></div>
          {% endif %}
          <div class="text-body" style="margin-top:1rem;opacity:.75;"><span data-shopify-editor-setting="contact_form_disclaimer">{{ section.settings.contact_form_disclaimer }}</span></div>
          {{ form.errors | default_errors }}
        {% endform %}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);border-top:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="section-header"><div><div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="contact_ecosystem_eyebrow">{{ section.settings.contact_ecosystem_eyebrow }}</span></div><h2 class="text-h2"><span data-shopify-editor-setting="contact_ecosystem_heading">{{ section.settings.contact_ecosystem_heading }}</span></h2></div></div>
      <div class="training-grid" style="margin-top:var(--space-lg);">
        {% for block in section.blocks %}
          {% if block.type == 'contact_ecosystem_card' %}
            {% liquid
              assign ecosystem_url = shop_url
              if block.settings.link_type == 'training'
                assign ecosystem_url = training_url
              elsif block.settings.link_type == 'street_miles'
                assign ecosystem_url = street_miles_url
              elsif block.settings.link_type == 'shop'
                assign ecosystem_url = shop_url
              elsif block.settings.link != blank
                assign ecosystem_url = block.settings.link
              endif
            %}
            <div class="training-card" {{ block.shopify_attributes }}><div class="training-card-title">{{ block.settings.title }}</div><div class="training-card-desc">{{ block.settings.description }}</div><div class="service-arrow" style="margin-top:1rem;"><a href="{{ ecosystem_url }}">{{ block.settings.link_label }}</a></div></div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  {% if page.content != blank %}<section class="section"><div class="container rte">{{ page.content }}</div></section>{% endif %}
  </div>

