{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign header_menu_handle = section.settings.header_menu | default: settings.header_menu
  assign header_menu_links = blank

  if header_menu_handle != blank and linklists[header_menu_handle] != blank
    assign header_menu_links = linklists[header_menu_handle].links
  endif
%}

<nav class="nav" id="main-nav" {{ section.shopify_attributes }}>
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }} home" data-shopify-editor-setting="logo">
      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
          alt="{{ shop.name | escape }}"
          class="nav-logo-image"
          style="width: {{ section.settings.logo_width }}px;"
        >
      {% elsif settings.logo != blank %}
        <img
          src="{{ settings.logo | image_url: width: settings.logo_width }}"
          alt="{{ shop.name | escape }}"
          class="nav-logo-image"
          style="width: {{ settings.logo_width }}px;"
        >
      {% else %}
        <img src="{{ 'aren-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" class="nav-logo-image">
      {% endif %}
    </a>

    <div class="nav-links">
      {% if header_menu_links != blank %}
        {% for link in header_menu_links %}
          <a href="{{ link.url }}" class="nav-link{% if link.current or link.active %} active{% endif %}" title="{{ link.title | escape }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ routes.root_url }}" class="nav-link{% if request.page_type == 'index' %} active{% endif %}" data-shopify-editor-setting="home_label">{{ section.settings.home_label | default: settings.header_home_label | default: 'Home' }}</a>
        <a href="{{ about_url }}" class="nav-link{% if handle == 'about' %} active{% endif %}" data-shopify-editor-setting="about_label">{{ section.settings.about_label | default: settings.header_about_label | default: 'About AREN' }}</a>
        <a href="{{ training_url }}" class="nav-link{% if handle == 'training' %} active{% endif %}" data-shopify-editor-setting="training_label">{{ section.settings.training_label | default: settings.header_training_label | default: 'Training' }}</a>
        <a href="{{ services_url }}" class="nav-link{% if handle == 'services' %} active{% endif %}" data-shopify-editor-setting="services_label">{{ section.settings.services_label | default: settings.header_services_label | default: 'Services' }}</a>
        <a href="{{ street_miles_url }}" class="nav-link{% if handle == 'street-miles' %} active{% endif %}" data-shopify-editor-setting="street_label">{{ section.settings.street_label | default: settings.header_street_label | default: 'Street Miles NYC' }}</a>
        <a href="{{ shop_url }}" class="nav-link{% if handle == 'shop' or request.page_type == 'collection' or request.page_type == 'product' %} active{% endif %}" data-shopify-editor-setting="shop_label">{{ section.settings.shop_label | default: settings.header_shop_label | default: 'Shop' }}</a>
        <a href="{{ contact_url }}" class="nav-link{% if handle == 'contact' %} active{% endif %}" data-shopify-editor-setting="contact_label">{{ section.settings.contact_label | default: settings.header_contact_label | default: 'Contact / Join' }}</a>
      {% endif %}
    </div>

    <div class="nav-actions">
      <a href="{{ routes.account_login_url }}" class="nav-action-link" data-shopify-editor-setting="login_label">{{ section.settings.login_label | default: settings.header_login_label | default: 'Log In' }}</a>
      <a href="{{ shop_url }}" class="nav-cta" data-shopify-editor-setting="cta_label">{{ section.settings.cta_label | default: settings.header_cta_label | default: 'Shop Now' }}</a>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" type="button">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="nav-mobile" id="nav-mobile">
  <div class="nav-mobile-links">
    {% if header_menu_links != blank %}
      {% for link in header_menu_links %}
        <a href="{{ link.url }}" class="nav-mobile-link" title="{{ link.title | escape }}">{{ link.title }}</a>
      {% endfor %}
    {% else %}
      <a href="{{ routes.root_url }}" class="nav-mobile-link" data-shopify-editor-setting="home_label">{{ section.settings.home_label | default: settings.header_home_label | default: 'Home' }}</a>
      <a href="{{ about_url }}" class="nav-mobile-link" data-shopify-editor-setting="about_label">{{ section.settings.about_label | default: settings.header_about_label | default: 'About AREN' }}</a>
      <a href="{{ training_url }}" class="nav-mobile-link" data-shopify-editor-setting="training_label">{{ section.settings.training_label | default: settings.header_training_label | default: 'Training' }}</a>
      <a href="{{ services_url }}" class="nav-mobile-link" data-shopify-editor-setting="services_label">{{ section.settings.services_label | default: settings.header_services_label | default: 'Services' }}</a>
      <a href="{{ street_miles_url }}" class="nav-mobile-link" data-shopify-editor-setting="street_label">{{ section.settings.street_label | default: settings.header_street_label | default: 'Street Miles NYC' }}</a>
      <a href="{{ shop_url }}" class="nav-mobile-link" data-shopify-editor-setting="shop_label">{{ section.settings.shop_label | default: settings.header_shop_label | default: 'Shop' }}</a>
      <a href="{{ contact_url }}" class="nav-mobile-link" data-shopify-editor-setting="contact_label">{{ section.settings.contact_label | default: settings.header_contact_label | default: 'Contact / Join' }}</a>
    {% endif %}
    <a href="{{ routes.account_login_url }}" class="nav-mobile-link" data-shopify-editor-setting="login_label">{{ section.settings.login_label | default: settings.header_login_label | default: 'Log In' }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Site header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo override" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 80, "max": 240, "step": 4, "unit": "px", "default": 160 },
    { "type": "link_list", "id": "header_menu", "label": "Header menu" },
    { "type": "text", "id": "home_label", "label": "Home label", "default": "Home" },
    { "type": "text", "id": "about_label", "label": "About label", "default": "About AREN" },
    { "type": "text", "id": "training_label", "label": "Training label", "default": "Training" },
    { "type": "text", "id": "services_label", "label": "Services label", "default": "Services" },
    { "type": "text", "id": "street_label", "label": "Street Miles label", "default": "Street Miles NYC" },
    { "type": "text", "id": "shop_label", "label": "Shop label", "default": "Shop" },
    { "type": "text", "id": "contact_label", "label": "Contact label", "default": "Contact / Join" },
    { "type": "text", "id": "login_label", "label": "Login label", "default": "Log In" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Now" }
  ]
}
{% endschema %}
