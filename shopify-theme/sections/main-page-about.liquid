{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign about_hero_image = section.settings.about_hero_image
  assign about_intro_image = section.settings.about_intro_image
  assign about_identity_image = section.settings.about_identity_image
  assign training_hero_image = section.settings.training_hero_image
  assign training_feature_image = section.settings.training_feature_image
  assign services_hero_image = section.settings.services_hero_image
  assign street_miles_hero_image = section.settings.street_miles_hero_image
  assign street_miles_culture_image = section.settings.street_miles_culture_image
  assign contact_hero_image = section.settings.contact_hero_image
  assign services_cta_image = section.settings.services_cta_image
  assign street_miles_quotes_image = section.settings.street_miles_quotes_image

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
  if section.settings.training_page != blank
    assign training_url = section.settings.training_page.url
  endif
  if section.settings.services_page != blank
    assign services_url = section.settings.services_page.url
  endif
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
  if section.settings.privacy_page != blank
    assign privacy_url = section.settings.privacy_page.url
  endif
  if section.settings.terms_page != blank
    assign terms_url = section.settings.terms_page.url
  endif
  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif
%}

  <div class="page-editor-surface page-editor-surface--about" data-page-handle="about" {{ section.shopify_attributes }}>
  <section class="page-hero page-hero--dark" style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:flex-end;">
    <div style="position:absolute;inset:0;{% if about_hero_image != blank %}background-image:url('{{ about_hero_image | image_url: width: 2000 }}');{% else %}background-image:url('https://static.wixstatic.com/media/8a3301_7e4d26bfdcf043e9a3212206d4f53db5~mv2.png/v1/crop/x_0,y_2215,w_4284,h_1845/fill/w_1920,h_1080,al_c,q_90,enc_auto/8a3301_7e4d26bfdcf043e9a3212206d4f53db5~mv2.png');{% endif %}background-size:cover;background-position:center;"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(165deg,rgba(28,28,26,0.88) 0%,rgba(35,35,33,0.68) 55%,rgba(26,26,24,0.92) 100%);"></div>
    <div class="container" style="position:relative;z-index:1;padding-bottom:var(--space-xl);">
      <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="about_hero_eyebrow">{{ section.settings.about_hero_eyebrow }}</span></div>
      <h1 class="text-display" style="color:#fff;max-width:16ch;margin-bottom:2rem;"><span data-shopify-editor-setting="about_hero_heading">{{ section.settings.about_hero_heading }}</span></h1>
    </div>
  </section>

  <div class="marquee-strip"><div class="marquee-track"><span class="marquee-text">{{ section.settings.about_marquee_text }}</span><span class="marquee-text">{{ section.settings.about_marquee_text }}</span></div></div>

  <section class="section" style="border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="about-intro-inner">
        <div>
          <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="about_intro_eyebrow">{{ section.settings.about_intro_eyebrow }}</span></div>
          <h2 class="text-h2" style="max-width:18ch;margin-bottom:2.5rem;"><span data-shopify-editor-setting="about_intro_heading">{{ section.settings.about_intro_heading }}</span></h2>
          <div style="position:relative;overflow:hidden;aspect-ratio:3/4;margin-top:2rem;">
            {% if about_intro_image != blank %}
              <img src="{{ about_intro_image | image_url: width: 1200 }}" alt="{{ about_intro_image.alt | default: 'AREN Athletic' | escape }}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
            {% else %}
              <img src="https://static.wixstatic.com/media/8a3301_84feeb8e93ac42eb8e302b7b56f9b6c3~mv2.png/v1/fill/w_800,h_1000,al_c,q_90,enc_auto/8a3301_84feeb8e93ac42eb8e302b7b56f9b6c3~mv2.png" alt="AREN Athletic" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
            {% endif %}
          </div>
          <div style="margin-top:2rem;"><a href="{{ shop_url }}" class="btn btn--outline"><span data-shopify-editor-setting="about_intro_button_label">{{ section.settings.about_intro_button_label }}</span></a></div>
        </div>
        <div>
          <div class="text-body rte"><span data-shopify-editor-setting="about_intro_richtext">{{ section.settings.about_intro_richtext }}</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="border-bottom:1px solid var(--color-warm-gray);">
    <div class="container container--narrow">
      <div class="text-body rte"><span data-shopify-editor-setting="about_body_richtext">{{ section.settings.about_body_richtext }}</span></div>
      <p style="font-family:var(--font-mono);font-size:0.5rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-mid-gray);"><span data-shopify-editor-setting="about_body_kicker">{{ section.settings.about_body_kicker }}</span></p>
    </div>
  </section>

  <section class="section" style="border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:start;">
        <div style="position:relative;overflow:hidden;aspect-ratio:3/4;">
          {% if about_identity_image != blank %}
            <img src="{{ about_identity_image | image_url: width: 1200 }}" alt="{{ about_identity_image.alt | default: 'AREN Athletic — What AREN Represents' | escape }}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
          {% else %}
            <img src="https://static.wixstatic.com/media/8a3301_c4e9e55c79fa424d9097c68e0bbe2892~mv2.png/v1/fill/w_800,h_1000,al_c,q_90,enc_auto/8a3301_c4e9e55c79fa424d9097c68e0bbe2892~mv2.png" alt="AREN Athletic — What AREN Represents" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" loading="lazy">
          {% endif %}
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(35,35,33,0.35) 0%,transparent 40%);"></div>
        </div>
        <div>
          <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="about_identity_eyebrow">{{ section.settings.about_identity_eyebrow }}</span></div>
          <h2 class="text-h2" style="max-width:18ch;margin-bottom:1.75rem;"><span data-shopify-editor-setting="about_identity_heading">{{ section.settings.about_identity_heading }}</span></h2>
          <div class="text-body rte"><span data-shopify-editor-setting="about_identity_richtext">{{ section.settings.about_identity_richtext }}</span></div>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--color-black);color:var(--color-white);padding:var(--space-xl) 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:start;">
        <div>
          <div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:2rem;"><span data-shopify-editor-setting="about_values_eyebrow">{{ section.settings.about_values_eyebrow }}</span></div>
          <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3.8rem);font-weight:700;line-height:0.95;letter-spacing:-0.01em;text-transform:uppercase;color:#fff;margin-bottom:2rem;"><span data-shopify-editor-setting="about_values_heading">{{ section.settings.about_values_heading }}</span></h2>
          <div class="rte" style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:46ch;"><span data-shopify-editor-setting="about_values_richtext">{{ section.settings.about_values_richtext }}</span></div>
          <p style="font-family:var(--font-mono);font-size:0.625rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.35);"><span data-shopify-editor-setting="about_values_kicker">{{ section.settings.about_values_kicker }}</span></p>
        </div>
        <div style="display:flex;flex-direction:column;gap:2rem;padding-left:var(--space-lg);border-left:1px solid rgba(255,255,255,0.08);">
          {% for block in section.blocks %}
            {% if block.type == 'about_value_card' %}
              <div style="padding:2.5rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);" {{ block.shopify_attributes }}>
                <div class="text-eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:1rem;">{{ block.settings.title }}</div>
                <p style="font-size:0.9375rem;line-height:1.7;color:rgba(255,255,255,0.5);">{{ block.settings.description }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <div style="background:var(--color-black);padding:1rem 0;border-top:1px solid rgba(255,255,255,0.06);overflow:hidden;white-space:nowrap;">
    <div style="display:inline-flex;animation:marquee 20s linear infinite;">
      <span style="font-family:var(--font-mono);font-size:0.5rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.2);padding:0 2rem;"><span data-shopify-editor-setting="about_footer_marquee_text">{{ section.settings.about_footer_marquee_text }}</span></span>
      <span style="font-family:var(--font-mono);font-size:0.5rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.2);padding:0 2rem;">{{ section.settings.about_footer_marquee_text }}</span>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);align-items:center;">
        <div>
          <div class="text-eyebrow" style="margin-bottom:2rem;"><span data-shopify-editor-setting="about_cta_eyebrow">{{ section.settings.about_cta_eyebrow }}</span></div>
          <h2 class="text-h2" style="max-width:22ch;margin-bottom:1.75rem;"><span data-shopify-editor-setting="about_cta_heading">{{ section.settings.about_cta_heading }}</span></h2>
          <p class="text-body" style="max-width:46ch;"><span data-shopify-editor-setting="about_cta_copy">{{ section.settings.about_cta_copy }}</span></p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem;max-width:400px;">
          <a href="{{ contact_url }}" class="btn btn--primary"><span data-shopify-editor-setting="about_cta_primary_label">{{ section.settings.about_cta_primary_label }}</span></a>
          <a href="{{ training_url }}" class="btn btn--outline"><span data-shopify-editor-setting="about_cta_secondary_label">{{ section.settings.about_cta_secondary_label }}</span></a>
          <a href="{{ street_miles_url }}" class="btn btn--outline"><span data-shopify-editor-setting="about_cta_tertiary_label">{{ section.settings.about_cta_tertiary_label }}</span></a>
        </div>
      </div>
    </div>
  </section>

  {% if page.content != blank %}
    <section class="section"><div class="container rte">{{ page.content }}</div></section>
  {% endif %}
  </div>

{% schema %}
{
  "name": "About page",
  "settings": [
    {
      "type": "header",
      "content": "About page editor settings"
    },
    {
      "type": "page",
      "id": "about_page",
      "label": "About page"
    },
    {
      "type": "page",
      "id": "training_page",
      "label": "Training page"
    },
    {
      "type": "page",
      "id": "services_page",
      "label": "Services page"
    },
    {
      "type": "page",
      "id": "street_miles_page",
      "label": "Street Miles page"
    },
    {
      "type": "page",
      "id": "contact_page",
      "label": "Contact page"
    },
    {
      "type": "page",
      "id": "privacy_page",
      "label": "Privacy page"
    },
    {
      "type": "page",
      "id": "terms_page",
      "label": "Terms page"
    },
    {
      "type": "page",
      "id": "shop_page",
      "label": "Shop page"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "text",
      "id": "about_hero_eyebrow",
      "label": "About hero eyebrow",
      "default": "About AREN"
    },
    {
      "type": "text",
      "id": "about_hero_heading",
      "label": "About hero heading",
      "default": "AREN isn't just apparel. AREN is a standard."
    },
    {
      "type": "image_picker",
      "id": "about_hero_image",
      "label": "About hero image"
    },
    {
      "type": "textarea",
      "id": "about_marquee_text",
      "label": "About marquee text",
      "default": "AREN ATHLETIC — NEW YORK CITY — DISCIPLINE AND PERFORMANCE — STREET MILES NYC — FIVE BOROUGH CHAPTER — STRUCTURED PERFORMANCE — AREN ATHLETIC COLLECTIVE — APPAREL BUILT FOR TRAINING —"
    },
    {
      "type": "text",
      "id": "about_intro_eyebrow",
      "label": "About intro eyebrow",
      "default": "About AREN"
    },
    {
      "type": "text",
      "id": "about_intro_heading",
      "label": "About intro heading",
      "default": "AREN Athletic"
    },
    {
      "type": "image_picker",
      "id": "about_intro_image",
      "label": "About intro image"
    },
    {
      "type": "text",
      "id": "about_intro_button_label",
      "label": "About intro button label",
      "default": "Shop Apparel"
    },
    {
      "type": "richtext",
      "id": "about_intro_richtext",
      "label": "About intro rich text",
      "default": "<p>AREN isn't just apparel. AREN is a standard.</p><p>It's the moment before the work begins. The quiet decision you make when no one is watching. The discipline to prepare, the courage to show up, and the commitment to hold the line when it would be easier not to.</p><p>AREN was built on three principles: discipline, presence, and consistency.</p><p>Discipline is the foundation. It's the shoe being tied before sunrise. It's the extra set, the extra mile, the extra moment of focus when fatigue tells you to stop. Discipline is not loud. It's not flashy. It's the daily choice to do what must be done.</p><p>Presence is how you carry yourself in the world. It's the way you enter the room, the gym, the track, the street, or the workplace. Presence means showing up prepared, composed, and ready for whatever the day demands.</p><p>Consistency is the separator. Anyone can show up once. Anyone can have a good day. But the standard is held by those who show up again and again, day after day, long after the excitement fades and the work becomes routine.</p><p><strong>That's where AREN lives.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "about_body_richtext",
      "label": "About body rich text",
      "default": "<p>AREN exists at the intersection of training and life: in the gym, on the street, at work, and in the quiet moments when you decide who you are going to be.</p><p>But the standard doesn't stop there. It carries into how you live, how you treat people, and the kind of character you build when the work of the day is done. It shows up in how you lead your family, how you support the people around you, and how you stand by your principles when life tests them.</p><p>This isn't clothing made for a moment. It's apparel designed for the standard you hold yourself to every day. When you wear AREN, you're not putting on a brand. You're stepping into a mindset. It means you carry discipline with you. You move with intention.</p><p><strong>You show up with presence.</strong></p><p>It means you respect the work. You respect the process. You respect the standard.</p><p>Because the standard isn't just performance. It's how you train. It's how you work.</p><p>It's how you carry yourself in every room you enter.</p><p>It's also how you show up for the people who depend on you, the values you live by, and the character you build when no one is watching.</p><p>The standard is the standard.</p><p>And the ones who live by it don't need to announce it.</p><p>You can see it in how they move, how they prepare, and how they show up.</p><p>AREN exists for those people. The ones who know the work never really ends. The ones who understand that greatness isn't built in moments of spotlight, but in the quiet hours where discipline becomes identity.</p><p><strong>Wear it with intention. Train with purpose. Carry the standard.</strong></p><p><strong>This is AREN.</strong></p>"
    },
    {
      "type": "text",
      "id": "about_body_kicker",
      "label": "About body kicker",
      "default": "EST. 2026. PERFORMANCE PROTOCOL."
    },
    {
      "type": "text",
      "id": "about_identity_eyebrow",
      "label": "About identity eyebrow",
      "default": "What AREN Represents"
    },
    {
      "type": "image_picker",
      "id": "about_identity_image",
      "label": "About identity image"
    },
    {
      "type": "text",
      "id": "about_identity_heading",
      "label": "About identity heading",
      "default": "A performance identity."
    },
    {
      "type": "richtext",
      "id": "about_identity_richtext",
      "label": "About identity rich text",
      "default": "<p>AREN is a performance identity.</p><p>Defined by discipline, presence, and execution.</p><p>Not a destination. A standard of conduct.</p><p>Training is deliberate. How you move through the world matters.</p><p>The apparel carries the code — a signal of restraint, readiness, and alignment.</p><p>The mark represents a standard — not attention. Wear it as a reflection of how you operate.</p>"
    },
    {
      "type": "text",
      "id": "about_values_eyebrow",
      "label": "About values eyebrow",
      "default": "No Spectators. Only Standards."
    },
    {
      "type": "html",
      "id": "about_values_heading",
      "label": "About values heading",
      "default": "NO SPECTATORS.<br>ONLY STANDARDS."
    },
    {
      "type": "richtext",
      "id": "about_values_richtext",
      "label": "About values rich text",
      "default": "<p>AREN rejects passivity and spectatorship in favor of ownership and responsibility.</p><p>The standard is a non-negotiable threshold of operation — a commitment to presence over distraction and execution over intention. To align with AREN is to accept accountability for how you show up: in training, in work, and in life.</p><p>We don't observe from the sidelines. We operate.</p>"
    },
    {
      "type": "text",
      "id": "about_values_kicker",
      "label": "About values kicker",
      "default": "There are no spectators. There are only standards."
    },
    {
      "type": "textarea",
      "id": "about_footer_marquee_text",
      "label": "About footer marquee text",
      "default": "DISCIPLINE • EXECUTION • STANDARDS • DISCIPLINE • EXECUTION • STANDARDS • DISCIPLINE • EXECUTION • STANDARDS • DISCIPLINE • EXECUTION • STANDARDS • DISCIPLINE • EXECUTION • STANDARDS •"
    },
    {
      "type": "text",
      "id": "about_cta_eyebrow",
      "label": "About CTA eyebrow",
      "default": "National Performance Platform"
    },
    {
      "type": "text",
      "id": "about_cta_heading",
      "label": "About CTA heading",
      "default": "Building a scalable culture of community chapters across the nation."
    },
    {
      "type": "textarea",
      "id": "about_cta_copy",
      "label": "About CTA copy",
      "default": "AREN is evolving into a coordinated performance ecosystem, establishing elite training protocols and community expression while maintaining the absolute integrity of the standard."
    },
    {
      "type": "text",
      "id": "about_cta_primary_label",
      "label": "About CTA primary label",
      "default": "Join the Collective"
    },
    {
      "type": "text",
      "id": "about_cta_secondary_label",
      "label": "About CTA secondary label",
      "default": "Explore Training"
    },
    {
      "type": "text",
      "id": "about_cta_tertiary_label",
      "label": "About CTA tertiary label",
      "default": "Join Street Miles NYC"
    }
  ],
  "blocks": [
    {
      "type": "about_value_card",
      "name": "About value card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Training Systems"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Engineered for high-pressure execution. Every protocol is designed to eliminate distraction and focus on the clarity of movement, ensuring consistency is maintained under the weight of the collective standard."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About page",
      "blocks": [
        {
          "type": "about_value_card",
          "settings": {
            "title": "Training Systems",
            "description": "Engineered for high-pressure execution. Every protocol is designed to eliminate distraction and focus on the clarity of movement, ensuring consistency is maintained under the weight of the collective standard."
          }
        },
        {
          "type": "about_value_card",
          "settings": {
            "title": "Performance Apparel",
            "description": "Functional apparel built with restraint and durability. The system is designed to move through training, recovery, and the city without sacrificing composure or utility."
          }
        },
        {
          "type": "about_value_card",
          "settings": {
            "title": "Street Miles",
            "description": "Community expression of the standard. Shared miles, structured accountability, and visible discipline carried into the streets of New York City."
          }
        }
      ]
    }
  ]
