{% schema %}
{
  "name": "Main page",
  "settings": [
    { "type": "page", "id": "about_page", "label": "About page" },
    { "type": "page", "id": "training_page", "label": "Training page" },
    { "type": "page", "id": "services_page", "label": "Services page" },
    { "type": "page", "id": "street_miles_page", "label": "Street Miles page" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "page", "id": "privacy_page", "label": "Privacy page" },
    { "type": "page", "id": "terms_page", "label": "Terms page" },
    { "type": "page", "id": "shop_page", "label": "Shop page" },
    { "type": "header", "content": "Shop page editor settings" },
    { "type": "text", "id": "shop_hero_heading", "label": "Shop hero heading", "default": "COMPOSURE UNDER PRESSURE." },
    { "type": "textarea", "id": "shop_hero_copy", "label": "Shop hero copy", "default": "Performance-informed apparel built for daily standards, not trends." },
    { "type": "text", "id": "shop_design_eyebrow", "label": "Shop design eyebrow", "default": "Design Philosophy" },
    { "type": "text", "id": "shop_design_heading", "label": "Shop design heading", "default": "FUNCTION. RESTRAINT. DURABILITY." },
    { "type": "text", "id": "shop_grid_eyebrow_left", "label": "Shop grid left label", "default": "All Pieces" },
    { "type": "text", "id": "shop_grid_eyebrow_right", "label": "Shop grid right label", "default": "Current Collection" },
    { "type": "collection", "id": "shop_collection", "label": "Shop collection" },
    { "type": "range", "id": "shop_products_limit", "label": "Shop products limit", "min": 4, "max": 24, "step": 1, "default": 12 },
    { "type": "text", "id": "shop_bottom_eyebrow", "label": "Shop bottom eyebrow", "default": "Why AREN Apparel" },
    { "type": "text", "id": "shop_bottom_heading", "label": "Shop bottom heading", "default": "NOT STREETWEAR.<br>A SYSTEM." },
    { "type": "textarea", "id": "shop_bottom_paragraph_1", "label": "Shop bottom paragraph 1", "default": "AREN apparel exists as an extension of the athlete's standard." },
    { "type": "textarea", "id": "shop_bottom_paragraph_2", "label": "Shop bottom paragraph 2", "default": "Not driven by seasonal trends or streetwear cycles, but by discipline, restraint, and functional precision." },
    { "type": "textarea", "id": "shop_bottom_paragraph_3", "label": "Shop bottom paragraph 3", "default": "Every piece is designed to hold up under training and carry that same standard into the rest of life." },
    { "type": "textarea", "id": "shop_bottom_paragraph_4", "label": "Shop bottom paragraph 4", "default": "This is not clothing for spectators." },
    { "type": "textarea", "id": "shop_bottom_paragraph_5", "label": "Shop bottom paragraph 5", "default": "It's equipment for people who operate." }
  ],
  "blocks": [
    {
      "type": "shop_pillar",
      "name": "Shop design pillar",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Training" },
        { "type": "text", "id": "description", "label": "Description", "default": "Engineered for high-output training environments." }
      ]
    },
    {
      "type": "shop_filter",
      "name": "Shop filter label",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Shop System" },
        { "type": "text", "id": "filter_key", "label": "Filter key", "default": "all" },
        { "type": "checkbox", "id": "active", "label": "Active by default", "default": false }
      ]
    },
    {
      "type": "shop_fallback_card",
      "name": "Shop fallback card",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Add Shopify products" },
        { "type": "text", "id": "description", "label": "Description", "default": "This shop page is ready for your real catalog." },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Theme Ready" },
        { "type": "text", "id": "background_color", "label": "Background color", "default": "#1e1e1c" }
      ]
    },
    {
      "type": "shop_info",
      "name": "Shop info item",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shipping" },
        { "type": "text", "id": "description", "label": "Description", "default": "Shipping nationwide on all orders." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main page",
      "blocks": [
        { "type": "shop_pillar", "settings": { "title": "Training", "description": "Engineered for high-output training environments." } },
        { "type": "shop_pillar", "settings": { "title": "Daily Wear", "description": "Structured comfort for transition and recovery days." } },
        { "type": "shop_pillar", "settings": { "title": "Outer Layers", "description": "Technical protection for environmental defense." } },
        { "type": "shop_filter", "settings": { "label": "Shop System", "filter_key": "all", "active": true } },
        { "type": "shop_filter", "settings": { "label": "New Arrivals", "filter_key": "new" } },
        { "type": "shop_filter", "settings": { "label": "Core Essentials", "filter_key": "core" } },
        { "type": "shop_filter", "settings": { "label": "Outerwear", "filter_key": "outerwear" } },
        { "type": "shop_filter", "settings": { "label": "Accessories", "filter_key": "accessories" } },
        { "type": "shop_fallback_card", "settings": { "title": "Add Shopify products", "description": "This shop page is ready for your real catalog.", "cta_label": "Theme Ready", "background_color": "#1e1e1c" } },
        { "type": "shop_info", "settings": { "title": "Shipping", "description": "Shipping nationwide on all orders." } },
        { "type": "shop_info", "settings": { "title": "Quality Standard", "description": "Built to last. Every piece carries the AREN standard." } },
        { "type": "shop_info", "settings": { "title": "Returns", "description": "30-day return policy on unworn items." } }
      ]
    }
  ]
}
{% endschema %}
