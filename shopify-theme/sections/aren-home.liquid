{% liquid
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign about_url = pages['about'].url | default: '/pages/about'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'

  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif

  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif

  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
%}

<div class="page-home" {{ section.shopify_attributes }}>
  <section class="page-hero page-hero--dark" style="position:relative;overflow:hidden;min-height:640px;display:flex;align-items:flex-end;">
    <div style="position:absolute;inset:0;{% if settings.default_hero_image != blank %}background-image:url('{{ settings.default_hero_image | image_url: width: 2200 }}');{% else %}background-image:url('https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=2000&q=80');{% endif %}background-size:cover;background-position:center;"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(165deg,rgba(28,28,26,0.88) 0%,rgba(35,35,33,0.68) 55%,rgba(26,26,24,0.92) 100%);"></div>
    <div class="container" style="position:relative;z-index:1;padding-bottom:var(--space-xl);">
      <div class="text-eyebrow" style="margin-bottom:2rem;color:rgba(255,255,255,0.35);">{{ section.settings.hero_eyebrow }}</div>
      <h1 class="text-display" style="color:#fff;max-width:16ch;margin-bottom:1.5rem;">{{ section.settings.hero_headline }}</h1>
      <p class="text-body" style="max-width:44ch;color:rgba(255,255,255,0.65);margin-bottom:2rem;">{{ section.settings.hero_subline }}</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem;">
        <a href="{{ shop_url }}" class="btn btn--primary">{{ section.settings.hero_primary_label }}</a>
        <a href="{{ contact_url }}" class="btn btn--outline-white">{{ section.settings.hero_secondary_label }}</a>
      </div>
      <div style="display:grid;gap:0.35rem;color:rgba(255,255,255,0.42);font-family:var(--font-mono);font-size:0.625rem;letter-spacing:0.18em;text-transform:uppercase;">
        <span>{{ section.settings.hero_microcopy_one }}</span>
        <span>{{ section.settings.hero_microcopy_two }}</span>
      </div>
    </div>
  </section>

  <div class="marquee-strip">
    <div class="marquee-track">
      <span class="marquee-text">{{ section.settings.marquee_text }}</span>
      <span class="marquee-text">{{ section.settings.marquee_text }}</span>
    </div>
  </div>

  <section class="section" style="border-bottom:1px solid var(--color-warm-gray);">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="text-eyebrow mb-sm">Category focus</div>
          <h2 class="text-h2">Shop by system.</h2>
        </div>
      </div>
      <div class="training-grid" style="margin-top:var(--space-lg);">
        {% for block in section.blocks %}
          {% if block.type == 'category' %}
            {% liquid
              assign category_url = shop_url
              if block.settings.link != blank
                assign category_url = block.settings.link
              endif
            %}
            <a href="{{ category_url }}" class="training-card" style="text-decoration:none;color:inherit;display:block;" {{ block.shopify_attributes }}>
              <div class="training-card-number">{{ block.settings.number }}</div>
              <div class="training-card-title">{{ block.settings.title }}</div>
              <div class="training-card-desc">{{ block.settings.description }}</div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <div class="text-eyebrow mb-sm">{{ section.settings.featured_eyebrow }}</div>
          <h2 class="text-h2">{{ section.settings.featured_heading }}</h2>
        </div>
        <a href="{{ shop_url }}" class="btn btn--ghost">{{ section.settings.featured_button_label }}</a>
      </div>
      <div class="product-grid">
        {% assign featured_collection = section.settings.featured_collection %}
        {% if featured_collection != blank and featured_collection.products_count > 0 %}
          {% for product in featured_collection.products limit: section.settings.featured_products_limit %}
            <a href="{{ product.url }}" style="text-decoration:none;color:inherit;" class="product-card">
              <div class="product-image" style="background:#f2efe9;">
                {% if product.featured_image %}
                  <img class="product-img" src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy">
                {% endif %}
                {% if product.tags.size > 0 %}
                  <div class="product-tag">{{ product.tags.first }}</div>
                {% endif %}
              </div>
              <div class="product-name">{{ product.title }}</div>
              {% if product.description != blank %}
                <div class="product-desc">{{ product.description | strip_html | truncate: 60 }}</div>
              {% endif %}
              <div class="product-price">{{ product.price | money }}</div>
            </a>
          {% endfor %}
        {% else %}
          {% for block in section.blocks %}
            {% if block.type == 'featured_card' %}
              {% liquid
                assign card_url = shop_url
                if block.settings.link != blank
                  assign card_url = block.settings.link
                endif
              %}
              <a href="{{ card_url }}" style="text-decoration:none;color:inherit;" class="product-card" {{ block.shopify_attributes }}>
                <div class="product-image" style="background:{{ block.settings.background_color }};">
                  {% if block.settings.image != blank %}
                    <img class="product-img" src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" loading="lazy">
                  {% endif %}
                  {% if block.settings.tag != blank %}
                    <div class="product-tag">{{ block.settings.tag }}</div>
                  {% endif %}
                </div>
                <div class="product-name">{{ block.settings.title }}</div>
                <div class="product-desc">{{ block.settings.description }}</div>
                <div class="product-price">{{ block.settings.cta_label }}</div>
              </a>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-black);color:var(--color-white);">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow mb-sm" style="color:rgba(255,255,255,0.3);">{{ section.settings.philosophy_eyebrow }}</div>
        <h2 class="text-h2" style="margin-bottom:1.5rem;color:#fff;">{{ section.settings.philosophy_headline }}</h2>
        <p class="text-body" style="max-width:42ch;margin-bottom:2rem;color:rgba(255,255,255,0.6);">{{ section.settings.philosophy_copy }}</p>
        <a href="{{ about_url }}" class="btn btn--outline-white">{{ section.settings.philosophy_button_label }}</a>
      </div>
      <div class="training-grid" style="grid-template-columns:1fr;gap:1rem;">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="training-card" style="background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.08);" {{ block.shopify_attributes }}>
              <div class="training-card-number" style="color:#fff;">{{ block.settings.value }}</div>
              <div class="training-card-title" style="color:#fff;">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.95fr);gap:var(--space-xl);align-items:center;">
      <div style="position:relative;overflow:hidden;aspect-ratio:4/5;background-size:cover;background-position:center;{% if settings.default_street_miles_image != blank %}background-image:url('{{ settings.default_street_miles_image | image_url: width: 1600 }}');{% else %}background-image:url('https://images.unsplash.com/photo-1483721310020-03333e577078?auto=format&fit=crop&w=1600&q=80');{% endif %}">
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(35,35,33,0.45) 0%,transparent 50%);"></div>
        <div style="position:absolute;left:1.5rem;bottom:1.5rem;right:1.5rem;color:#fff;z-index:1;">
          <div class="text-eyebrow" style="color:rgba(255,255,255,0.35);margin-bottom:1rem;">SMNYC / FIVE BOROUGH CHAPTER</div>
          <div class="text-h2" style="color:#fff;">Do the work.<br>Carry the weight.</div>
        </div>
      </div>
      <div>
        <div class="text-eyebrow mb-sm">{{ section.settings.street_eyebrow }}</div>
        <h2 class="text-h2" style="margin-bottom:1.25rem;">{{ section.settings.street_heading }}</h2>
        <p class="text-body" style="margin-bottom:2rem;max-width:42ch;">{{ section.settings.street_copy }}</p>
        <div class="training-grid" style="grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;margin-bottom:2rem;">
          {% for block in section.blocks %}
            {% if block.type == 'street_stat' %}
              <div class="training-card" {{ block.shopify_attributes }}>
                <div class="training-card-number">{{ block.settings.value }}</div>
                <div class="training-card-title">{{ block.settings.label }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <a href="{{ street_miles_url }}" class="btn btn--outline">{{ section.settings.street_button_label }}</a>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);border-top:1px solid var(--color-warm-gray);">
    <div class="container" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,.9fr);gap:var(--space-xl);align-items:start;">
      <div>
        <div class="text-eyebrow">{{ section.settings.signup_eyebrow }}</div>
        <h2 class="text-h2" style="margin-top:1.25rem;margin-bottom:1rem;">{{ section.settings.signup_heading }}</h2>
        <p class="text-body">{{ section.settings.signup_copy }}</p>
      </div>
      <div>
        {% form 'customer', class: 'signup-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="signup-form-row">
            <input type="email" class="signup-input" placeholder="Email address" required id="signup-email" name="contact[email]">
            <button type="submit" class="signup-btn">Join</button>
          </div>
          <p class="signup-disclaimer">{{ section.settings.signup_disclaimer }}</p>
          {% if form.posted_successfully? %}
            <div id="signup-success" style="display:block;" class="text-eyebrow">You're on the list.</div>
          {% endif %}
          {{ form.errors | default_errors }}
        {% endform %}
      </div>
    </div>
  </section>
</div>
{% schema %}
{
  "name": "AREN Home",
  "settings": [
    { "type": "page", "id": "shop_page", "label": "Shop page" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "page", "id": "about_page", "label": "About page" },
    { "type": "page", "id": "street_miles_page", "label": "Street Miles page" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "AREN ATHLETIC" },
    { "type": "text", "id": "hero_headline", "label": "Hero headline", "default": "Apparel built for training—and everything after." },
    { "type": "textarea", "id": "hero_subline", "label": "Hero subline", "default": "Minimal. Durable. Elevated. Designed for the gym, the street, and the pace of New York." },
    { "type": "text", "id": "hero_primary_label", "label": "Hero primary button label", "default": "Shop Apparel" },
    { "type": "text", "id": "hero_secondary_label", "label": "Hero secondary button label", "default": "Join the Community" },
    { "type": "text", "id": "hero_microcopy_one", "label": "Hero microcopy line 1", "default": "New drops + core staples • Shipping nationwide" },
    { "type": "text", "id": "hero_microcopy_two", "label": "Hero microcopy line 2", "default": "Quiet confidence. Built to wear daily." },
    { "type": "textarea", "id": "marquee_text", "label": "Marquee text", "default": "AREN ATHLETIC — NEW YORK CITY — DISCIPLINE AND PERFORMANCE — STREET MILES NYC — FIVE BOROUGH CHAPTER — STRUCTURED PERFORMANCE — AREN ATHLETIC COLLECTIVE — APPAREL BUILT FOR TRAINING —" },
    { "type": "text", "id": "featured_eyebrow", "label": "Featured section eyebrow", "default": "Featured Apparel" },
    { "type": "text", "id": "featured_heading", "label": "Featured section heading", "default": "The standard pieces." },
    { "type": "text", "id": "featured_button_label", "label": "Featured section button label", "default": "View All" },
    { "type": "collection", "id": "featured_collection", "label": "Featured products collection" },
    { "type": "range", "id": "featured_products_limit", "label": "Featured products limit", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "philosophy_eyebrow", "label": "Philosophy eyebrow", "default": "Brand Philosophy" },
    { "type": "text", "id": "philosophy_headline", "label": "Philosophy headline", "default": "The standard is the standard." },
    { "type": "textarea", "id": "philosophy_copy", "label": "Philosophy copy", "default": "AREN is built on discipline, presence, and consistency — apparel designed to perform in training and carry the standard everywhere else in life." },
    { "type": "text", "id": "philosophy_button_label", "label": "Philosophy button label", "default": "About AREN" },
    { "type": "text", "id": "street_eyebrow", "label": "Street Miles eyebrow", "default": "Street Miles" },
    { "type": "text", "id": "street_heading", "label": "Street Miles heading", "default": "Street Miles NYC" },
    { "type": "textarea", "id": "street_copy", "label": "Street Miles copy", "default": "A weekly run club built on exploration, effort, and community — moving through the city together." },
    { "type": "text", "id": "street_button_label", "label": "Street Miles button label", "default": "Explore Street Miles" },
    { "type": "text", "id": "signup_eyebrow", "label": "Signup eyebrow", "default": "Community Signup" },
    { "type": "text", "id": "signup_heading", "label": "Signup heading", "default": "Join the AREN list." },
    { "type": "textarea", "id": "signup_copy", "label": "Signup copy", "default": "Drops, restocks, and community updates — sent when it matters." },
    { "type": "text", "id": "signup_disclaimer", "label": "Signup disclaimer", "default": "No spam. Unsubscribe any time." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "New Arrivals" },
        { "type": "text", "id": "description", "label": "Description", "default": "Latest drops, limited runs." },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "featured_card",
      "name": "Featured fallback card",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Tag", "default": "Featured" },
        { "type": "text", "id": "title", "label": "Title", "default": "Tonal Men's Box Tee — Black" },
        { "type": "text", "id": "description", "label": "Description", "default": "Sharp structure. Everyday system." },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop" },
        { "type": "text", "id": "background_color", "label": "Background color", "default": "#1e1e1c" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "stat",
      "name": "Philosophy stat",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "NYC" },
        { "type": "text", "id": "label", "label": "Label", "default": "Home Chapter — Five Boroughs" }
      ]
    },
    {
      "type": "street_stat",
      "name": "Street Miles stat",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "5" },
        { "type": "text", "id": "label", "label": "Label", "default": "Boroughs" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AREN Home",
      "blocks": [
        { "type": "category", "settings": { "number": "01", "title": "New Arrivals", "description": "Latest drops, limited runs." } },
        { "type": "category", "settings": { "number": "02", "title": "Core Essentials", "description": "The foundation—clean, repeatable, durable." } },
        { "type": "category", "settings": { "number": "03", "title": "Outerwear", "description": "Layers built for movement and weather." } },
        { "type": "featured_card", "settings": { "tag": "Featured", "title": "Tonal Men's Box Tee — Black", "description": "Sharp structure. Everyday system.", "cta_label": "Shop", "background_color": "#1e1e1c" } },
        { "type": "featured_card", "settings": { "tag": "Core", "title": "Structured Warmth Layer", "description": "Built for daily wear.", "cta_label": "Shop", "background_color": "#d8d3c5" } },
        { "type": "featured_card", "settings": { "tag": "Accessory", "title": "Essential Cap", "description": "Clean finish. All week.", "cta_label": "Shop", "background_color": "#e8dfc8" } },
        { "type": "featured_card", "settings": { "title": "Performance Layer", "description": "Training-ready. Street-ready.", "cta_label": "Shop", "background_color": "#232321" } },
        { "type": "stat", "settings": { "value": "NYC", "label": "Home Chapter — Five Boroughs" } },
        { "type": "stat", "settings": { "value": "Daily", "label": "Standard — Not Seasonal" } },
        { "type": "stat", "settings": { "value": "One", "label": "System — Built to Perform" } },
        { "type": "street_stat", "settings": { "value": "5", "label": "Boroughs" } },
        { "type": "street_stat", "settings": { "value": "Sun", "label": "09:00 Sharp" } },
        { "type": "street_stat", "settings": { "value": "NYC", "label": "Home Chapter" } }
      ]
    }
  ]
}
{% endschema %}
