{% liquid
  assign about_url = pages['about'].url | default: '/pages/about'
  assign training_url = pages['training'].url | default: '/pages/training'
  assign services_url = pages['services'].url | default: '/pages/services'
  assign street_miles_url = pages['street-miles'].url | default: '/pages/street-miles'
  assign contact_url = pages['contact'].url | default: '/pages/contact'
  assign privacy_url = pages['privacy'].url | default: '/pages/privacy'
  assign terms_url = pages['terms'].url | default: '/pages/terms'
  assign shop_url = pages['shop'].url | default: '/pages/shop'
  assign about_hero_image = section.settings.about_hero_image
  assign about_intro_image = section.settings.about_intro_image
  assign about_identity_image = section.settings.about_identity_image
  assign training_hero_image = section.settings.training_hero_image
  assign training_feature_image = section.settings.training_feature_image
  assign services_hero_image = section.settings.services_hero_image
  assign street_miles_hero_image = section.settings.street_miles_hero_image
  assign street_miles_culture_image = section.settings.street_miles_culture_image
  assign contact_hero_image = section.settings.contact_hero_image
  assign services_cta_image = section.settings.services_cta_image
  assign street_miles_quotes_image = section.settings.street_miles_quotes_image

  if section.settings.about_page != blank
    assign about_url = section.settings.about_page.url
  endif
  if section.settings.training_page != blank
    assign training_url = section.settings.training_page.url
  endif
  if section.settings.services_page != blank
    assign services_url = section.settings.services_page.url
  endif
  if section.settings.street_miles_page != blank
    assign street_miles_url = section.settings.street_miles_page.url
  endif
  if section.settings.contact_page != blank
    assign contact_url = section.settings.contact_page.url
  endif
  if section.settings.privacy_page != blank
    assign privacy_url = section.settings.privacy_page.url
  endif
  if section.settings.terms_page != blank
    assign terms_url = section.settings.terms_page.url
  endif
  if section.settings.shop_page != blank
    assign shop_url = section.settings.shop_page.url
  endif
%}

  <div class="page-editor-surface page-editor-surface--privacy" data-page-handle="privacy" {{ section.shopify_attributes }}>
  <section class="section" style="padding-top:calc(68px + var(--space-xl));">
    <div class="container container--narrow">
      <div class="text-eyebrow mb-sm"><span data-shopify-editor-setting="privacy_eyebrow">{{ section.settings.privacy_eyebrow }}</span></div>
      <h1 class="text-display" style="margin-bottom:2rem;"><span data-shopify-editor-setting="privacy_heading">{{ section.settings.privacy_heading }}</span></h1>
      <div class="text-body">
        <p style="margin-bottom:1.75rem;"><span data-shopify-editor-setting="privacy_intro">{{ section.settings.privacy_intro }}</span></p>
        <h2 style="font-family:var(--font-sans);font-size:0.875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin:2.5rem 0 1rem;"><span data-shopify-editor-setting="privacy_section_1_heading">{{ section.settings.privacy_section_1_heading }}</span></h2>
        <p style="margin-bottom:1.75rem;"><span data-shopify-editor-setting="privacy_section_1_body">{{ section.settings.privacy_section_1_body }}</span></p>
        <h2 style="font-family:var(--font-sans);font-size:0.875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin:2.5rem 0 1rem;"><span data-shopify-editor-setting="privacy_section_2_heading">{{ section.settings.privacy_section_2_heading }}</span></h2>
        <p style="margin-bottom:1.75rem;"><span data-shopify-editor-setting="privacy_section_2_body">{{ section.settings.privacy_section_2_body }}</span></p>
        <h2 style="font-family:var(--font-sans);font-size:0.875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin:2.5rem 0 1rem;"><span data-shopify-editor-setting="privacy_contact_heading">{{ section.settings.privacy_contact_heading }}</span></h2>
        <p style="margin-bottom:1.75rem;"><span data-shopify-editor-setting="privacy_contact_copy">{{ section.settings.privacy_contact_copy }}</span> <a href="mailto:{{ settings.email_address | default: 'info@arenathletic.com' }}">{{ settings.email_address | default: 'info@arenathletic.com' }}</a>.</p>
        <p style="font-family:var(--font-mono);font-size:0.5rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-mid-gray);margin-top:4rem;"><span data-shopify-editor-setting="privacy_footer_note">{{ section.settings.privacy_footer_note }}</span></p>
        <div style="margin-top:3rem;">
          <a href="{{ routes.root_url }}" style="font-family:var(--font-mono);font-size:0.625rem;letter-spacing:0.16em;text-transform:uppercase;text-decoration:none;color:var(--color-black);"><span data-shopify-editor-setting="legal_back_label">{{ section.settings.legal_back_label }}</span></a>
        </div>
      </div>
    </div>
  </section>
  </div>

{% schema %}
{
  "name": "Privacy page",
  "settings": [
    { "type": "header", "content": "Legal page editor settings" },
    { "type": "page", "id": "about_page", "label": "About page" },
    { "type": "page", "id": "training_page", "label": "Training page" },
    { "type": "page", "id": "services_page", "label": "Services page" },
    { "type": "page", "id": "street_miles_page", "label": "Street Miles page" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "page", "id": "privacy_page", "label": "Privacy page" },
    { "type": "page", "id": "terms_page", "label": "Terms page" },
    { "type": "page", "id": "shop_page", "label": "Shop page" },
    { "type": "text", "id": "privacy_eyebrow", "label": "Privacy eyebrow", "default": "Legal" },
    { "type": "text", "id": "privacy_heading", "label": "Privacy heading", "default": "Privacy Policy" },
    { "type": "textarea", "id": "privacy_intro", "label": "Privacy intro", "default": "AREN ATHLETIC (\"AREN,\" \"we,\" \"us,\" or \"our\") respects your privacy. This Privacy Policy describes how we collect, use, and protect information you provide when you visit arenathletic.com or engage with our services." },
    { "type": "text", "id": "privacy_section_1_heading", "label": "Privacy section 1 heading", "default": "Information We Collect" },
    { "type": "textarea", "id": "privacy_section_1_body", "label": "Privacy section 1 body", "default": "We collect information you voluntarily provide (name, email, phone) when you submit inquiry forms or sign up for community updates. We do not sell your personal information to third parties." },
    { "type": "text", "id": "privacy_section_2_heading", "label": "Privacy section 2 heading", "default": "How We Use Your Information" },
    { "type": "textarea", "id": "privacy_section_2_body", "label": "Privacy section 2 body", "default": "Information collected is used solely for AREN Athletic communications: responding to inquiries, sending community updates you have opted into, and coordinating training or community access." },
    { "type": "text", "id": "privacy_contact_heading", "label": "Privacy contact heading", "default": "Contact" },
    { "type": "text", "id": "privacy_contact_copy", "label": "Privacy contact copy", "default": "For privacy inquiries, contact us at" },
    { "type": "text", "id": "privacy_footer_note", "label": "Privacy footer note", "default": "Last updated: 2026. AREN ATHLETIC. NEW YORK CITY." },
    { "type": "text", "id": "legal_back_label", "label": "Legal back link label", "default": "Back to home" }
  ],
  "blocks": [
  ],
  "presets": [
    {
      "name": "Privacy page"
    }
  ]
}
{% endschema %}
